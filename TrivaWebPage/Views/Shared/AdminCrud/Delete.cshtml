@model object
@{
    var title = (ViewBag.DisplayName as string) ?? "Delete";
    ViewData["Title"] = $"Delete {title}";
    var id = Model?.GetType().GetProperty("Id")?.GetValue(Model);
}

<div class="space-y-4">
    <h1 class="text-2xl font-semibold">Delete @title</h1>
    <p>Are you sure you want to delete this record?</p>
    <pre class="rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder p-4 text-sm whitespace-pre-wrap">@System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
    <form asp-action="Delete" method="post" class="flex gap-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@id" />
        <button class="rounded bg-red-600 text-white px-4 py-2" type="submit">Delete</button>
        <a asp-action="Index">Cancel</a>
    </form>
</div>
