@model TrivaWebPage.ViewModels.Admin.LoginViewModel
@using System.Text.Json
@{
    Layout = null;
    ViewData["Title"] = "Giriş";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Triva</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" />
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Inter", sans-serif;
            background: #e4ddd3;
            color: #12211f;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }
        .card {
            width: 100%;
            max-width: 400px;
            background: #fff;
            border-radius: 1rem;
            padding: 2rem;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
            border: 2px solid #00a19b;
        }
        h1 {
            font-family: "Manrope", sans-serif;
            font-size: 1.5rem;
            margin: 0 0 1.5rem;
            color: #00a19b;
        }
        label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.35rem; }
        input[type="text"], input[type="password"] {
            width: 100%;
            padding: 0.65rem 0.75rem;
            border: 1px solid rgba(0, 161, 155, 0.45);
            border-radius: 0.5rem;
            font-size: 1rem;
            background: #e4ddd3;
        }
        input:focus {
            outline: none;
            border-color: #00a19b;
            box-shadow: 0 0 0 3px rgba(0, 161, 155, 0.2);
        }
        .field { margin-bottom: 1rem; }
        .pw-wrap { position: relative; }
        .pw-wrap input { padding-right: 2.75rem; }
        .toggle-pw {
            position: absolute;
            right: 0.35rem;
            top: 50%;
            transform: translateY(-50%);
            border: none;
            background: transparent;
            cursor: pointer;
            padding: 0.35rem;
            color: #00a19b;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .toggle-pw .material-symbols-outlined { font-size: 22px; }
        .remember { display: flex; align-items: center; gap: 0.5rem; margin: 1rem 0; font-size: 0.875rem; }
        button[type="submit"] {
            width: 100%;
            padding: 0.75rem 1rem;
            border: none;
            border-radius: 0.5rem;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            background: #00a19b;
            color: #fff;
        }
        button[type="submit"]:hover { filter: brightness(1.05); }
        .validation { color: #b91c1c; font-size: 0.875rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Triva Admin</h1>
        <form asp-action="Login" method="post" asp-route-returnUrl="@returnUrl">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation"></div>
            <div class="field">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" autocomplete="username" />
            </div>
            <div class="field">
                <label asp-for="Password"></label>
                <div class="pw-wrap">
                    <input asp-for="Password" id="loginPassword" type="password" autocomplete="current-password" />
                    <button type="button" class="toggle-pw" id="togglePw" aria-label="Şifreyi göster veya gizle">
                        <span class="material-symbols-outlined" id="togglePwIcon">visibility</span>
                    </button>
                </div>
            </div>
            <div class="remember">
                <input asp-for="RememberMe" type="checkbox" />
                <label asp-for="RememberMe" style="margin:0;font-weight:400;">Beni hatırla</label>
            </div>
            <button type="submit">Giriş yap</button>
        </form>
    </div>
    <script>
        (function () {
            var input = document.getElementById("loginPassword");
            var btn = document.getElementById("togglePw");
            var icon = document.getElementById("togglePwIcon");
            if (input) {
                var preset = @Html.Raw(JsonSerializer.Serialize(Model.Password ?? string.Empty));
                if (preset) input.value = preset;
            }
            if (!input || !btn || !icon) return;
            btn.addEventListener("click", function () {
                if (input.type === "password") {
                    input.type = "text";
                    icon.textContent = "visibility_off";
                } else {
                    input.type = "password";
                    icon.textContent = "visibility";
                }
            });
        })();
    </script>
</body>
</html>
