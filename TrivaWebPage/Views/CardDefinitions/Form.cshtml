@model TrivaWebPage.ViewModels.Admin.CardDefinitionEditViewModel
@{
    var formAction = (ViewBag.FormAction as string) ?? "Create";
    var title = (ViewBag.DisplayName as string) ?? "Card Definitions";
    ViewData["Title"] = $"{title} {formAction}";
}

<div class="space-y-4 max-w-4xl">
    <h1 class="text-2xl font-semibold text-brand-lightText dark:text-brand-darkText">@title @formAction</h1>

    <form asp-action="@formAction" asp-route-id="@(formAction == "Edit" ? Model.Id : null)" method="post" class="space-y-4 rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder p-4">
        @Html.AntiForgeryToken()
        @if (formAction == "Edit")
        {
            <input type="hidden" asp-for="Id" />
        }
        <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

        <div class="space-y-1">
            <label class="block text-sm font-medium" asp-for="Name">Name</label>
            <input class="w-full rounded border px-3 py-2 text-black" asp-for="Name" />
            <span asp-validation-for="Name" class="text-red-600 text-xs"></span>
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium" asp-for="Code">Code</label>
            <input class="w-full rounded border px-3 py-2 text-black" asp-for="Code" />
            <span asp-validation-for="Code" class="text-red-600 text-xs"></span>
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium" asp-for="CardType">CardType</label>
            <input class="w-full rounded border px-3 py-2 text-black" asp-for="CardType" />
            <span asp-validation-for="CardType" class="text-red-600 text-xs"></span>
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium" asp-for="Description">Description</label>
            <textarea class="w-full rounded border px-3 py-2 text-black text-sm min-h-[72px]" asp-for="Description"></textarea>
        </div>

        <input type="hidden" asp-for="PreviewHtml" />

        <div class="space-y-2 rounded-lg border border-dashed border-brand-lightBorder dark:border-brand-darkBorder p-3 bg-white">
            <p class="text-xs font-medium text-brand-lightText dark:text-brand-darkText">Render edilmiş kart önizlemesi (HTML kodu gizli)</p>
            @if (string.IsNullOrWhiteSpace(Model.PreviewHtml))
            {
                <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">
                    Bu tanımda gösterilecek HTML bulunamadı. Kartlar ekranından yüklenen HTML kartlar burada yalnızca render edilmiş haliyle görünür.
                </p>
            }
            else
            {
                @await Html.PartialAsync("~/Views/CardDefinitions/_CardDefinitionLightPreviewIframe.cshtml", Model.PreviewHtml)
            }
        </div>

        <div class="flex items-center gap-2">
            <input type="checkbox" asp-for="IsActive" />
            <label asp-for="IsActive" class="text-sm">IsActive</label>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="rounded bg-brand-lightAccent dark:bg-brand-darkAccent text-white px-4 py-2">Save</button>
            <a asp-action="Index" class="px-2 py-2 text-sm">Cancel</a>
        </div>
    </form>
</div>
