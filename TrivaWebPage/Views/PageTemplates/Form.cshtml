@model TrivaWebPage.ViewModels.Admin.PageTemplateEditViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Şablon oluştur" : "Şablon düzenle";
    var isEdit = Model.Id > 0;
    var pageCount = Model.Pages?.Count ?? 0;
}

<div class="space-y-4 max-w-5xl">
    <h1 class="text-2xl font-semibold">@ViewData["Title"]</h1>

    @if (isEdit && pageCount > 1)
    {
        <div class="rounded-lg border border-amber-300/80 bg-amber-50 px-4 py-2 text-sm text-amber-900 dark:border-amber-800 dark:bg-amber-950/40 dark:text-amber-100">
            Bu şablonda <strong>@pageCount</strong> iç sayfa var. ZIP yükleyerek veya aşağıdaki HTML alanına yazarak tümünü değiştirebilirsiniz; HTML alanını boş bırakırsanız mevcut sayfalar korunur.
        </div>
    }

    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)"
          method="post" enctype="multipart/form-data" class="space-y-6 rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder p-4">
        @Html.AntiForgeryToken()
        @if (isEdit)
        {
            <input type="hidden" asp-for="Id" />
        }
        <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

        <div class="space-y-1">
            <label class="block text-sm font-medium" asp-for="Name">Şablon adı</label>
            <input class="w-full rounded border px-3 py-2 text-black" asp-for="Name" />
            <span asp-validation-for="Name" class="text-red-600 text-xs"></span>
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium" asp-for="MasterHtml">HTML kod</label>
            <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">ZIP kullanmıyorsanız tek sayfa olarak kaydedilir. ZIP kullanıyorsanız bu alanı boş bırakabilirsiniz.</p>
            <textarea class="w-full rounded border px-3 py-2 text-black font-mono min-h-[200px]" asp-for="MasterHtml"></textarea>
        </div>

        <div class="rounded-lg border border-dashed border-brand-lightBorder dark:border-brand-darkBorder p-4 space-y-2">
            <h2 class="font-semibold text-sm">ZIP (HTML + CSS + JS)</h2>
            <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">ZIP içindeki tüm dosyalar sunucuya çıkarılır; her .html dosyası ayrı şablon içi sayfa olur. Göreli yollar için otomatik <code>&lt;base href&gt;</code> eklenir.</p>
            <input type="file" name="zipArchive" accept=".zip" class="text-sm" />
        </div>

        <div class="rounded-lg border border-dashed border-brand-lightBorder dark:border-brand-darkBorder p-4 space-y-2">
            <h2 class="font-semibold text-sm">Önizleme resmi</h2>
            <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">İlk şablon içi sayfanın önizlemesinde kullanılır (JPG, PNG, GIF, WEBP).</p>
            <input type="file" name="previewImage" accept=".jpg,.jpeg,.png,.gif,.webp" class="text-sm" />
        </div>

        <div class="flex gap-3">
            <button type="submit" class="rounded bg-brand-lightAccent dark:bg-brand-darkAccent text-white px-4 py-2">Kaydet</button>
            <a asp-action="Index" class="px-2 py-2">İptal</a>
        </div>
    </form>
</div>
