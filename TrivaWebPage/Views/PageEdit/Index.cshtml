@using System.Text.Encodings.Web
@using System.Text.Json
@model TrivaWebPage.ViewModels.Admin.PageEditIndexViewModel
@{
    ViewData["Title"] = "Sayfa düzenle";
    var activePage = Model.ActivePage;
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var payload = JsonSerializer.Serialize(activePage?.Items ?? [], jsonOpts);
    var safePayload = JavaScriptEncoder.Default.Encode(payload);
    var cardsJson = JsonSerializer.Serialize(Model.Cards, jsonOpts);
    var safeCards = JavaScriptEncoder.Default.Encode(cardsJson);
    var mediaJson = JsonSerializer.Serialize(Model.PageMedia, jsonOpts);
    var safeMedia = JavaScriptEncoder.Default.Encode(mediaJson);
}

<div class="max-w-[1600px] mx-auto space-y-4">
    <div class="flex items-center justify-between gap-3">
        <h1 class="text-2xl font-semibold text-brand-lightText dark:text-brand-darkText">Sayfa düzenle</h1>
        @if (activePage is not null)
        {
            <button type="button"
                    id="savePageEditBtn"
                    class="rounded-lg bg-brand-lightAccent dark:bg-brand-darkAccent px-4 py-2 text-sm font-medium text-white hover:opacity-90">
                Kaydet
            </button>
        }
    </div>

    @if (TempData["PageEditError"] is string err)
    {
        <div class="rounded-xl border border-red-300/80 bg-red-50 px-4 py-3 text-sm text-red-900 dark:border-red-800 dark:bg-red-950/50 dark:text-red-100">@err</div>
    }
    @if (TempData["PageEditMessage"] is string okMsg)
    {
        <div class="rounded-xl border border-emerald-300/80 bg-emerald-50 px-4 py-3 text-sm text-emerald-900 dark:border-emerald-800 dark:bg-emerald-950/50 dark:text-emerald-100">@okMsg</div>
    }

    <div class="flex flex-wrap gap-2 border-b border-brand-lightBorder dark:border-brand-darkBorder pb-2">
        @foreach (var p in Model.Pages)
        {
            var active = Model.ActivePageId == p.Id;
            <a asp-action="Index" asp-route-pageId="@p.Id"
               class="rounded-t-lg px-4 py-2 text-sm font-medium transition max-w-[12rem] truncate @(active
                   ? "bg-brand-lightPanel dark:bg-brand-darkPanel text-brand-lightText dark:text-brand-darkText border border-b-0 border-brand-lightBorder dark:border-brand-darkBorder -mb-px"
                   : "text-brand-lightMuted dark:text-brand-darkMuted hover:text-brand-lightText dark:hover:text-brand-darkText")"
               title="@p.Name">@p.Name</a>
        }
    </div>

    @if (activePage is null)
    {
        <div class="rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-6 text-sm text-brand-lightMuted dark:text-brand-darkMuted">
            Düzenlenecek bir sayfa bulunamadı.
        </div>
    }
    else
    {
        <form id="savePageEditForm" asp-action="Save" method="post" class="hidden">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PageId" value="@activePage.PageId" />
            <input type="hidden" name="PayloadJson" id="payloadJsonInput" value="@payload" />
        </form>

        <div class="rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-3 space-y-3">
            <div class="flex flex-wrap items-end gap-3 border-b border-brand-lightBorder dark:border-brand-darkBorder pb-3">
                <div class="min-w-[8rem]">
                    <p class="text-xs uppercase text-brand-lightMuted dark:text-brand-darkMuted">Sayfa</p>
                    <p class="text-sm font-medium truncate max-w-[14rem]">@activePage.PageName</p>
                    <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">@activePage.PageWidth × @activePage.PageHeight px</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button type="button" id="addTextBoxBtn" class="rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 text-sm hover:bg-black/5 dark:hover:bg-white/5">+ Metin kutusu</button>
                    <button type="button" id="removeTextBoxBtn" class="rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 text-sm hover:bg-black/5 dark:hover:bg-white/5">Seçiliyi sil</button>
                </div>
                <label class="flex items-center gap-2 text-sm cursor-pointer border rounded-lg px-3 py-2 border-brand-lightBorder dark:border-brand-darkBorder">
                    <input type="checkbox" id="resizeHandlesToggle" checked />
                    Köşeden boyutlandır
                </label>
                <div class="flex flex-wrap items-center gap-2 border-l border-brand-lightBorder dark:border-brand-darkBorder pl-3">
                    <span class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Zoom</span>
                    <button type="button" id="zoomOutBtn" class="h-8 min-w-8 rounded-md border border-brand-lightBorder bg-white px-2 text-base font-bold text-black hover:bg-black/5">-</button>
                    <button type="button" id="zoomResetBtn" class="h-8 min-w-[64px] rounded-md border border-brand-lightBorder bg-white px-2 text-sm font-semibold text-black hover:bg-black/5">100%</button>
                    <button type="button" id="zoomInBtn" class="h-8 min-w-8 rounded-md border border-brand-lightBorder bg-white px-2 text-base font-bold text-black hover:bg-black/5">+</button>
                </div>
                <div class="flex flex-wrap gap-2 items-end flex-1 min-w-[240px]">
                    <div class="space-y-1 flex-1 min-w-[120px]">
                        <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Yazı tipi</label>
                        <select id="fontFamily" class="w-full rounded border px-2 py-1.5 text-black text-sm">
                            @foreach (var font in Model.FontOptions)
                            {
                                <option value="@font">@font</option>
                            }
                        </select>
                    </div>
                    <div class="space-y-1 w-20">
                        <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Boyut</label>
                        <input id="fontSize" type="number" min="8" max="144" class="w-full rounded border px-2 py-1.5 text-black text-sm" value="16" />
                    </div>
                    <div class="space-y-1 w-24">
                        <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Renk</label>
                        <input id="textColor" type="color" class="h-9 w-full rounded border bg-white p-1" value="#111111" />
                    </div>
                    <div class="flex gap-1">
                        <button type="button" data-toggle-style="bold" class="style-btn rounded border px-2 py-1 text-sm font-semibold">B</button>
                        <button type="button" data-toggle-style="italic" class="style-btn rounded border px-2 py-1 text-sm italic">I</button>
                        <button type="button" data-toggle-style="underline" class="style-btn rounded border px-2 py-1 text-sm underline">U</button>
                    </div>
                    <div class="flex gap-1">
                        <button type="button" data-align="left" class="align-btn rounded border px-2 py-1 text-xs">Sola</button>
                        <button type="button" data-align="center" class="align-btn rounded border px-2 py-1 text-xs">Ortala</button>
                        <button type="button" data-align="right" class="align-btn rounded border px-2 py-1 text-xs">Sağa</button>
                    </div>
                </div>
            </div>

            <div class="grid gap-3 lg:grid-cols-[minmax(0,200px)_1fr]">
                <aside class="space-y-3 rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder p-3 bg-white/50 dark:bg-black/10 order-2 lg:order-1">
                    <p class="text-xs font-semibold uppercase text-brand-lightMuted dark:text-brand-darkMuted">Sayfa görselleri</p>
                    <form asp-action="UploadMedia" method="post" enctype="multipart/form-data" class="space-y-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="pageId" value="@activePage.PageId" />
                        <input type="file" name="file" accept=".jpg,.jpeg,.png,.gif,.webp" class="text-xs w-full" required />
                        <button type="submit" class="w-full rounded border border-brand-lightAccent bg-brand-lightAccent px-2 py-1.5 text-xs font-medium text-white dark:bg-brand-darkAccent">Yükle</button>
                    </form>
                    <div id="pageMediaThumbs" class="grid grid-cols-2 gap-2 max-h-[420px] overflow-y-auto"></div>
                </aside>

                <div id="templateViewport" class="relative order-1 lg:order-2 rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-white p-3 overflow-auto min-h-[480px]">
                    <p class="text-xs font-semibold text-brand-lightMuted dark:text-brand-darkMuted mb-2">Şablon önizleme · @(
                        string.IsNullOrWhiteSpace(activePage.TemplatePageName) ? "İç sayfa yok" : activePage.TemplatePageName)</p>
                    <div class="relative rounded-xl border border-dashed border-brand-lightBorder dark:border-brand-darkBorder bg-white shadow-sm mx-auto"
                         style="width:@($"{activePage.PageWidth}px"); height:@($"{activePage.PageHeight}px"); max-width:none;"
                         id="pageCanvas">
                        <iframe id="templateFrame" class="absolute inset-0 h-full w-full border-0 bg-white z-0" scrolling="yes"></iframe>
                    </div>
                    <div id="cardPreviewStrip" class="mt-4 space-y-2"></div>
                </div>
            </div>
        </div>
    }
</div>

@if (activePage is not null)
{
    <script>
        (function () {
            const initialItems = JSON.parse("@Html.Raw(safePayload)");
            const pageMedia = JSON.parse("@Html.Raw(safeMedia)");
            const cardPreviews = JSON.parse("@Html.Raw(safeCards)");
            const templateHtml = @Html.Raw(JsonSerializer.Serialize(activePage.TemplateHtml ?? ""));
            const canvas = document.getElementById("pageCanvas");
            const viewport = document.getElementById("templateViewport");
            const templateFrame = document.getElementById("templateFrame");
            const payloadInput = document.getElementById("payloadJsonInput");
            const saveBtn = document.getElementById("savePageEditBtn");
            const saveForm = document.getElementById("savePageEditForm");
            const addBtn = document.getElementById("addTextBoxBtn");
            const removeBtn = document.getElementById("removeTextBoxBtn");
            const zoomInBtn = document.getElementById("zoomInBtn");
            const zoomOutBtn = document.getElementById("zoomOutBtn");
            const zoomResetBtn = document.getElementById("zoomResetBtn");
            const fontFamily = document.getElementById("fontFamily");
            const fontSize = document.getElementById("fontSize");
            const textColor = document.getElementById("textColor");
            const alignButtons = Array.from(document.querySelectorAll(".align-btn"));
            const styleButtons = Array.from(document.querySelectorAll(".style-btn"));
            const resizeToggle = document.getElementById("resizeHandlesToggle");
            const mediaThumbs = document.getElementById("pageMediaThumbs");
            const cardStrip = document.getElementById("cardPreviewStrip");
            const pageId = @activePage.PageId;
            const tokenInput = saveForm?.querySelector('input[name="__RequestVerificationToken"]');

            if (!canvas || !viewport || !templateFrame || !payloadInput || !saveBtn || !saveForm) return;
            let templateZoom = 1;

            document.documentElement.classList.remove("dark");
            localStorage.setItem("theme", "light");

            const state = {
                items: initialItems.map((item) => ({
                    componentId: item.componentId || 0,
                    displayOrder: item.displayOrder || 0,
                    x: item.x || 0,
                    y: item.y || 0,
                    width: item.width || 240,
                    height: item.height || 120,
                    isVisible: item.isVisible !== false,
                    content: item.content || "",
                    fontFamily: item.fontFamily || "Inter",
                    fontSize: item.fontSize || 16,
                    fontWeight: item.fontWeight || null,
                    textColor: item.textColor || "#111111",
                    textAlign: item.textAlign || "left",
                    isBold: !!item.isBold,
                    isItalic: !!item.isItalic,
                    isUnderline: !!item.isUnderline
                })),
                selectedIndex: -1,
                editingIndex: -1
            };

            function renderMediaThumbs() {
                if (!mediaThumbs) return;
                mediaThumbs.innerHTML = "";
                pageMedia.forEach((m) => {
                    const wrap = document.createElement("div");
                    wrap.className = "relative group rounded border border-brand-lightBorder overflow-hidden";
                    const img = document.createElement("img");
                    img.src = m.filePath;
                    img.alt = m.displayName || "";
                    img.className = "h-20 w-full object-cover";
                    wrap.appendChild(img);
                    const rm = document.createElement("form");
                    rm.method = "post";
                    rm.action = "@Url.Action("RemovePageMedia")";
                    rm.className = "absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition";
                    const t = document.createElement("input");
                    t.type = "hidden";
                    t.name = "__RequestVerificationToken";
                    t.value = tokenInput ? tokenInput.value : "";
                    rm.appendChild(t);
                    const p = document.createElement("input");
                    p.type = "hidden"; p.name = "pageId"; p.value = String(pageId);
                    rm.appendChild(p);
                    const mid = document.createElement("input");
                    mid.type = "hidden"; mid.name = "mediaFileId"; mid.value = String(m.mediaFileId);
                    rm.appendChild(mid);
                    const btn = document.createElement("button");
                    btn.type = "submit";
                    btn.className = "rounded bg-red-600 text-white text-[10px] px-1 py-0.5";
                    btn.textContent = "×";
                    rm.appendChild(btn);
                    wrap.appendChild(rm);
                    mediaThumbs.appendChild(wrap);
                });
            }

            function renderCardStrip() {
                if (!cardStrip) return;
                cardStrip.innerHTML = "";
                if (!cardPreviews.length) {
                    cardStrip.innerHTML = '<p class="text-xs text-brand-lightMuted">Bu sayfada kart yok. Kartlar sayfasından HTML ile ekleyebilirsiniz.</p>';
                    return;
                }
                const title = document.createElement("p");
                title.className = "text-xs font-semibold text-brand-lightMuted";
                title.textContent = "Kartlar (önizleme)";
                cardStrip.appendChild(title);
                const row = document.createElement("div");
                row.className = "flex flex-wrap gap-2";
                cardPreviews.forEach((c) => {
                    const box = document.createElement("div");
                    box.className = "rounded border border-brand-lightBorder bg-white/90 p-2 text-xs max-w-[200px] shadow-sm";
                    if (c.htmlFragment) {
                        const ph = document.createElement("div");
                        ph.className = "text-[11px] max-h-24 overflow-hidden prose prose-sm";
                        ph.innerHTML = c.htmlFragment;
                        box.appendChild(ph);
                    } else {
                        const t = document.createElement("div");
                        t.className = "font-medium truncate";
                        t.textContent = c.title || "Kart";
                        box.appendChild(t);
                        if (c.showImage && c.mediaFilePath) {
                            const im = document.createElement("img");
                            im.src = c.mediaFilePath;
                            im.className = "mt-1 h-16 w-full object-cover rounded";
                            box.appendChild(im);
                        }
                    }
                    row.appendChild(box);
                });
                cardStrip.appendChild(row);
            }

            function updateToolbar() {
                const item = state.items[state.selectedIndex];
                if (!item) return;
                fontFamily.value = item.fontFamily || "Inter";
                fontSize.value = item.fontSize || 16;
                textColor.value = item.textColor || "#111111";

                styleButtons.forEach((btn) => {
                    const key = btn.dataset.toggleStyle;
                    const active = key === "bold" ? item.isBold : key === "italic" ? item.isItalic : item.isUnderline;
                    btn.classList.toggle("bg-brand-lightAccent", active);
                    btn.classList.toggle("dark:bg-brand-darkAccent", active);
                    btn.classList.toggle("text-white", active);
                });

                alignButtons.forEach((btn) => {
                    const active = btn.dataset.align === item.textAlign;
                    btn.classList.toggle("bg-brand-lightAccent", active);
                    btn.classList.toggle("dark:bg-brand-darkAccent", active);
                    btn.classList.toggle("text-white", active);
                });
            }

            function createBoxElement(item, index) {
                const box = document.createElement("div");
                box.className = "absolute rounded border border-brand-lightAccent/60 dark:border-brand-darkAccent/60 bg-white/90 shadow-sm z-10 select-none";
                box.dataset.index = index;
                box.style.left = item.x + "px";
                box.style.top = item.y + "px";
                box.style.width = item.width + "px";
                box.style.height = item.height + "px";
                box.style.display = item.isVisible ? "block" : "none";

                const textArea = document.createElement("textarea");
                textArea.className = "w-full h-full resize-none border-0 bg-transparent p-2 text-sm focus:outline-none";
                textArea.readOnly = true;
                textArea.tabIndex = 0;
                textArea.value = item.content || "";
                textArea.style.fontFamily = item.fontFamily || "Inter";
                textArea.style.fontSize = (item.fontSize || 16) + "px";
                textArea.style.color = item.textColor || "#111111";
                textArea.style.fontWeight = item.isBold ? "700" : "400";
                textArea.style.fontStyle = item.isItalic ? "italic" : "normal";
                textArea.style.textDecoration = item.isUnderline ? "underline" : "none";
                textArea.style.textAlign = item.textAlign || "left";
                textArea.style.pointerEvents = "none";
                textArea.style.cursor = "move";
                textArea.addEventListener("input", () => {
                    state.items[index].content = textArea.value;
                });
                textArea.addEventListener("blur", () => {
                    if (state.editingIndex === index) {
                        setEditMode(textArea, index, false);
                    }
                });
                textArea.addEventListener("mousedown", (e) => {
                    if (!textArea.readOnly) e.stopPropagation();
                });

                box.addEventListener("click", (e) => {
                    if (e.target === textArea && !textArea.readOnly) return;
                    select(index);
                });
                box.addEventListener("dblclick", (e) => {
                    e.preventDefault();
                    select(index);
                    setEditMode(textArea, index, true);
                    textArea.focus();
                });

                const handle = document.createElement("div");
                handle.className = "absolute -bottom-1 -right-1 h-3 w-3 cursor-se-resize rounded bg-brand-lightAccent dark:bg-brand-darkAccent resize-handle";
                handle.title = "Boyutlandır";

                function syncResizeVisibility() {
                    const on = resizeToggle && resizeToggle.checked;
                    handle.style.display = on ? "block" : "none";
                }
                syncResizeVisibility();

                enablePointerDrag(box, index, textArea);
                enableResize(handle, box, index);

                box.appendChild(textArea);
                box.appendChild(handle);
                return box;
            }

            function setEditMode(textArea, index, isEditing) {
                state.editingIndex = isEditing ? index : -1;
                textArea.readOnly = !isEditing;
                textArea.style.pointerEvents = isEditing ? "auto" : "none";
                textArea.style.cursor = isEditing ? "text" : "move";
                const box = textArea.parentElement;
                if (box) {
                    box.style.cursor = isEditing ? "text" : "move";
                }
                if (!isEditing) {
                    textArea.blur();
                }
            }

            function closeEditingIfAny() {
                if (state.editingIndex < 0) return;
                const activeTextArea = canvas.querySelector(`.absolute[data-index="${state.editingIndex}"] textarea`);
                if (activeTextArea) {
                    setEditMode(activeTextArea, state.editingIndex, false);
                } else {
                    state.editingIndex = -1;
                }
            }

            function select(index) {
                state.selectedIndex = index;
                render();
            }

            function render() {
                const oldNodes = Array.from(canvas.querySelectorAll(".absolute[data-index]"));
                oldNodes.forEach((n) => n.remove());

                state.items.forEach((item, idx) => {
                    const node = createBoxElement(item, idx);
                    if (idx === state.selectedIndex) {
                        node.classList.add("ring-2", "ring-brand-lightAccent", "dark:ring-brand-darkAccent");
                    }
                    canvas.appendChild(node);
                });

                updateToolbar();
            }

            function loadTemplateFrame() {
                const doc = templateFrame.contentDocument;
                if (!doc) return;

                doc.open();
                doc.write(templateHtml);
                doc.close();

                const style = doc.createElement("style");
                style.textContent = ".__texts-template-selected{outline:2px solid #00a19b!important;outline-offset:2px!important;}";
                doc.head.appendChild(style);

                const root = doc.documentElement;
                root.style.setProperty("transform", "none");
                root.style.setProperty("overflow", "auto");
                root.style.setProperty("zoom", "normal");
                if (doc.body) {
                    doc.body.style.overflow = "auto";
                    doc.body.style.zoom = "normal";
                    doc.body.style.margin = "0";
                    doc.body.style.minHeight = "100%";
                }

                let selectedNode = null;
                doc.addEventListener("click", (event) => {
                    const target = event.target;
                    if (!target || !target.tagName) return;
                    if (target.tagName === "HTML" || target.tagName === "BODY" || target.tagName === "HEAD") return;
                    if (selectedNode) selectedNode.classList.remove("__texts-template-selected");
                    selectedNode = target;
                    selectedNode.classList.add("__texts-template-selected");
                }, true);

                doc.addEventListener("dblclick", (event) => {
                    const target = event.target;
                    if (!target || !target.tagName) return;
                    if (!["P", "SPAN", "H1", "H2", "H3", "H4", "H5", "H6", "LI", "A", "BUTTON", "DIV"].includes(target.tagName)) return;
                    target.setAttribute("contenteditable", "true");
                    target.focus();
                }, true);

                if (zoomResetBtn) zoomResetBtn.textContent = "100%";
                viewport.style.overflow = "auto";
            }

            function applyTemplateZoom() {
                const doc = templateFrame.contentDocument;
                if (!doc?.body || !doc.documentElement) return;
                doc.body.style.zoom = String(templateZoom);
                if (zoomResetBtn) zoomResetBtn.textContent = Math.round(templateZoom * 100) + "%";
                doc.documentElement.style.overflow = templateZoom > 1 ? "auto" : "auto";
                doc.body.style.overflow = "auto";
            }

            function clamp(value, min, max) {
                return Math.min(Math.max(value, min), max);
            }

            function enablePointerDrag(node, index, textArea) {
                let active = false;
                let originX = 0;
                let originY = 0;
                let startX = 0;
                let startY = 0;

                node.addEventListener("pointerdown", (event) => {
                    if (textArea.readOnly === false) return;
                    if (event.target.classList.contains("resize-handle")) return;
                    active = true;
                    node.setPointerCapture(event.pointerId);
                    select(index);
                    originX = event.clientX;
                    originY = event.clientY;
                    startX = state.items[index].x;
                    startY = state.items[index].y;
                    event.preventDefault();
                });

                node.addEventListener("pointermove", (event) => {
                    if (!active) return;
                    const item = state.items[index];
                    const canvasRect = canvas.getBoundingClientRect();
                    const dx = event.clientX - originX;
                    const dy = event.clientY - originY;
                    item.x = clamp(Math.round(startX + dx), 0, canvasRect.width - item.width);
                    item.y = clamp(Math.round(startY + dy), 0, canvasRect.height - item.height);
                    node.style.left = item.x + "px";
                    node.style.top = item.y + "px";
                });

                node.addEventListener("pointerup", (event) => {
                    if (!active) return;
                    active = false;
                    try { node.releasePointerCapture(event.pointerId); } catch (_) { }
                });
                node.addEventListener("pointercancel", (event) => {
                    active = false;
                    try { node.releasePointerCapture(event.pointerId); } catch (_) { }
                });
            }

            function enableResize(handle, node, index) {
                let active = false;
                let originX = 0;
                let originY = 0;
                let startW = 0;
                let startH = 0;

                handle.addEventListener("pointerdown", (event) => {
                    active = true;
                    handle.setPointerCapture(event.pointerId);
                    select(index);
                    originX = event.clientX;
                    originY = event.clientY;
                    startW = state.items[index].width;
                    startH = state.items[index].height;
                    event.preventDefault();
                    event.stopPropagation();
                });

                handle.addEventListener("pointermove", (event) => {
                    if (!active) return;
                    const item = state.items[index];
                    const canvasRect = canvas.getBoundingClientRect();
                    const dw = event.clientX - originX;
                    const dh = event.clientY - originY;
                    const nextW = clamp(startW + dw, 80, canvasRect.width - item.x);
                    const nextH = clamp(startH + dh, 40, canvasRect.height - item.y);
                    item.width = Math.round(nextW);
                    item.height = Math.round(nextH);
                    node.style.width = item.width + "px";
                    node.style.height = item.height + "px";
                });

                handle.addEventListener("pointerup", (event) => {
                    active = false;
                    try { handle.releasePointerCapture(event.pointerId); } catch (_) { }
                });
                handle.addEventListener("pointercancel", () => { active = false; });
            }

            addBtn?.addEventListener("click", () => {
                const next = {
                    componentId: 0,
                    displayOrder: state.items.length + 1,
                    x: 30 + (state.items.length * 10),
                    y: 30 + (state.items.length * 10),
                    width: 260,
                    height: 120,
                    isVisible: true,
                    content: "",
                    fontFamily: "Inter",
                    fontSize: 16,
                    fontWeight: null,
                    textColor: "#111111",
                    textAlign: "left",
                    isBold: false,
                    isItalic: false,
                    isUnderline: false
                };
                state.items.push(next);
                state.selectedIndex = state.items.length - 1;
                render();
            });

            removeBtn?.addEventListener("click", () => {
                closeEditingIfAny();
                if (state.selectedIndex < 0) return;
                state.items.splice(state.selectedIndex, 1);
                state.selectedIndex = Math.min(state.selectedIndex, state.items.length - 1);
                render();
            });

            fontFamily?.addEventListener("change", () => {
                const item = state.items[state.selectedIndex];
                if (!item) return;
                item.fontFamily = fontFamily.value;
                render();
            });
            fontSize?.addEventListener("change", () => {
                const item = state.items[state.selectedIndex];
                if (!item) return;
                item.fontSize = Number(fontSize.value) || 16;
                render();
            });
            textColor?.addEventListener("change", () => {
                const item = state.items[state.selectedIndex];
                if (!item) return;
                item.textColor = textColor.value;
                render();
            });

            styleButtons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const item = state.items[state.selectedIndex];
                    if (!item) return;
                    const key = btn.dataset.toggleStyle;
                    if (key === "bold") item.isBold = !item.isBold;
                    if (key === "italic") item.isItalic = !item.isItalic;
                    if (key === "underline") item.isUnderline = !item.isUnderline;
                    render();
                });
            });

            alignButtons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const item = state.items[state.selectedIndex];
                    if (!item) return;
                    item.textAlign = btn.dataset.align || "left";
                    render();
                });
            });

            saveBtn.addEventListener("click", () => {
                closeEditingIfAny();
                const payload = state.items.map((x, index) => ({
                    componentId: x.componentId || 0,
                    displayOrder: index + 1,
                    x: Math.round(x.x || 0),
                    y: Math.round(x.y || 0),
                    width: Math.round(x.width || 240),
                    height: Math.round(x.height || 120),
                    isVisible: x.isVisible !== false,
                    content: (x.content || "").trim(),
                    fontFamily: x.fontFamily || "Inter",
                    fontSize: Number(x.fontSize || 16),
                    fontWeight: x.isBold ? "700" : "400",
                    textColor: x.textColor || "#111111",
                    textAlign: x.textAlign || "left",
                    isBold: !!x.isBold,
                    isItalic: !!x.isItalic,
                    isUnderline: !!x.isUnderline
                }));

                payloadInput.value = JSON.stringify(payload);
                saveForm.submit();
            });

            zoomInBtn?.addEventListener("click", () => {
                templateZoom = Math.min(2, Number((templateZoom + 0.1).toFixed(2)));
                applyTemplateZoom();
            });
            zoomOutBtn?.addEventListener("click", () => {
                templateZoom = Math.max(0.5, Number((templateZoom - 0.1).toFixed(2)));
                applyTemplateZoom();
            });
            zoomResetBtn?.addEventListener("click", () => {
                templateZoom = 1;
                applyTemplateZoom();
            });

            resizeToggle?.addEventListener("change", () => {
                document.querySelectorAll(".resize-handle").forEach((h) => {
                    h.style.display = resizeToggle.checked ? "block" : "none";
                });
            });

            document.addEventListener("pointerdown", (event) => {
                if (!canvas.contains(event.target)) {
                    closeEditingIfAny();
                }
            });

            canvas.addEventListener("pointerdown", (event) => {
                const clickedInsideTextBox = !!event.target.closest(".absolute[data-index]");
                if (!clickedInsideTextBox) {
                    closeEditingIfAny();
                }
            });

            renderMediaThumbs();
            renderCardStrip();
            loadTemplateFrame();
            render();
        })();
    </script>
}
