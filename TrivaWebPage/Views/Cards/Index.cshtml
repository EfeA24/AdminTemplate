@using System.Text.Encodings.Web
@using System.Text.Json
@model TrivaWebPage.ViewModels.Admin.CardsBuilderViewModel
@{
    ViewData["Title"] = "Kartlar";
    var activePage = Model.ActivePage;
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var cardsPayload = JsonSerializer.Serialize(activePage?.Items ?? [], jsonOpts);
    var mediaPayload = JsonSerializer.Serialize(Model.PageMedia ?? [], jsonOpts);
    var defsPayload = JsonSerializer.Serialize(Model.CardDefinitions ?? [], jsonOpts);
    var safeCardsPayload = JavaScriptEncoder.Default.Encode(cardsPayload);
    var safeMediaPayload = JavaScriptEncoder.Default.Encode(mediaPayload);
    var safeDefsPayload = JavaScriptEncoder.Default.Encode(defsPayload);
}

<div class="max-w-[1600px] mx-auto space-y-4">
    <div class="flex items-center justify-between gap-3">
        <h1 class="text-2xl font-semibold text-brand-lightText dark:text-brand-darkText">Kartlar</h1>
        @if (activePage is not null)
        {
            <button type="button" id="saveCardsBtn" class="rounded-lg bg-brand-lightAccent dark:bg-brand-darkAccent px-4 py-2 text-sm font-medium text-white hover:opacity-90">
                Kaydet
            </button>
        }
    </div>

    @if (TempData["CardsError"] is string error)
    {
        <div class="rounded-xl border border-red-300/80 bg-red-50 px-4 py-3 text-sm text-red-900 dark:border-red-800 dark:bg-red-950/50 dark:text-red-100">@error</div>
    }
    @if (TempData["CardsMessage"] is string ok)
    {
        <div class="rounded-xl border border-emerald-300/80 bg-emerald-50 px-4 py-3 text-sm text-emerald-900 dark:border-emerald-800 dark:bg-emerald-950/50 dark:text-emerald-100">@ok</div>
    }

    <div class="flex flex-wrap gap-2 border-b border-brand-lightBorder dark:border-brand-darkBorder pb-2">
        @foreach (var p in Model.Pages)
        {
            var active = Model.ActivePageId == p.Id;
            <a asp-action="Index" asp-route-pageId="@p.Id"
               class="rounded-t-lg px-4 py-2 text-sm font-medium transition max-w-[12rem] truncate @(active
                   ? "bg-brand-lightPanel dark:bg-brand-darkPanel text-brand-lightText dark:text-brand-darkText border border-b-0 border-brand-lightBorder dark:border-brand-darkBorder -mb-px"
                   : "text-brand-lightMuted dark:text-brand-darkMuted hover:text-brand-lightText dark:hover:text-brand-darkText")"
               title="@p.Name">@p.Name</a>
        }
    </div>

    @if (activePage is null)
    {
        <div class="rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-6 text-sm text-brand-lightMuted dark:text-brand-darkMuted">
            Düzenlenecek bir sayfa bulunamadı.
        </div>
    }
    else
    {
        <form id="saveCardsForm" asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PageId" value="@activePage.PageId" />
            <input type="hidden" name="PayloadJson" id="cardsPayloadInput" value="@cardsPayload" />
        </form>

        <div class="rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-4 space-y-4">
            <div class="space-y-2">
                <label class="text-sm font-semibold">HTML ile kart ekle</label>
                <textarea id="htmlCardInput" class="w-full min-h-[100px] rounded border px-3 py-2 text-black text-sm font-mono" placeholder="<div>...</div>"></textarea>
                <button type="button" id="addHtmlCardBtn" class="rounded-lg bg-brand-lightAccent dark:bg-brand-darkAccent px-4 py-2 text-sm font-medium text-white">Kartı ekle</button>
            </div>

            <div class="space-y-2 border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3">
                <label class="text-sm font-semibold text-brand-lightText dark:text-brand-darkText">Hazır kart tanımları</label>
                <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Card Definitions kayıtlarından; HTML önizlemesi light ortamda canvas’ta gösterilir.</p>
                <div id="cardDefPresets" class="flex flex-wrap gap-2"></div>
            </div>

            <div class="flex flex-wrap gap-3 items-center border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3">
                <button type="button" id="removeCardBtn" class="rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 text-sm">Seçili kartı sil</button>
                <span class="text-xs text-brand-lightMuted">Kart üzerine tıklayarak seçin. Varsayılan kartlarda görsele çift tıklayınca sayfa görsellerinden seçebilirsiniz.</span>
            </div>

            <div id="cardsRow" class="grid grid-cols-2 gap-4"></div>
        </div>

        <div id="imagePickerModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
            <div class="max-w-lg w-full rounded-xl bg-white p-4 shadow-lg space-y-3">
                <div class="flex justify-between items-center">
                    <h2 class="font-semibold text-lg">Görsel seç</h2>
                    <button type="button" id="closeImageModal" class="text-2xl leading-none">&times;</button>
                </div>
                <div id="imagePickerGrid" class="grid grid-cols-3 gap-2 max-h-80 overflow-y-auto"></div>
                <p class="text-xs text-gray-500">Görselleri sayfa düzenle ekranından yükleyin.</p>
            </div>
        </div>
    }
</div>

@if (activePage is not null)
{
    <script>
        (function () {
            const initialCards = JSON.parse("@Html.Raw(safeCardsPayload)");
            const pageMedia = JSON.parse("@Html.Raw(safeMediaPayload)");
            const cardDefinitions = JSON.parse("@Html.Raw(safeDefsPayload)");
            const pageId = @activePage.PageId;
            const canvas = document.getElementById("cardsRow");
            const saveBtn = document.getElementById("saveCardsBtn");
            const payloadInput = document.getElementById("cardsPayloadInput");
            const saveForm = document.getElementById("saveCardsForm");
            const addHtmlBtn = document.getElementById("addHtmlCardBtn");
            const htmlInput = document.getElementById("htmlCardInput");
            const removeBtn = document.getElementById("removeCardBtn");
            const modal = document.getElementById("imagePickerModal");
            const modalGrid = document.getElementById("imagePickerGrid");
            const closeModal = document.getElementById("closeImageModal");
            const presetsHost = document.getElementById("cardDefPresets");
            const token = document.querySelector('#saveCardsForm input[name="__RequestVerificationToken"]')?.value || "";

            if (!canvas || !saveBtn || !payloadInput || !saveForm) return;

            let selectedIndex = -1;
            let pickerTargetIndex = -1;

            const loremTitle = "Lorem ipsum dolor sit amet";
            const loremBody = "Consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.";
            const loremBtn = "Lorem ipsum";

            function pickRandomPageMedia() {
                if (!pageMedia || !pageMedia.length) return null;
                return pageMedia[Math.floor(Math.random() * pageMedia.length)];
            }

            const state = {
                cards: initialCards.map(normalizeCard)
            };

            function normalizeCard(c) {
                return {
                    componentId: c.componentId || 0,
                    cardComponentId: c.cardComponentId || 0,
                    displayOrder: c.displayOrder || 0,
                    x: c.x || 0,
                    y: c.y || 0,
                    width: c.width || 320,
                    height: c.height || 320,
                    isVisible: c.isVisible !== false,
                    cardDefinitionId: c.cardDefinitionId || 1,
                    title: c.title || "",
                    subtitle: c.subtitle || "",
                    description: c.description || "",
                    htmlFragment: c.htmlFragment || "",
                    mediaFileId: c.mediaFileId || null,
                    mediaFilePath: c.mediaFilePath || "",
                    showImage: !!c.showImage,
                    showButton: c.showButton !== false,
                    backgroundColor: c.backgroundColor || "#ffffff",
                    textColor: c.textColor || "#111827",
                    borderColor: c.borderColor || "#d1d5db",
                    buttons: Array.isArray(c.buttons) ? c.buttons.map(b => ({
                        id: b.id || 0,
                        displayOrder: b.displayOrder || 1,
                        text: b.text || "",
                        icon: b.icon || "",
                        backgroundColor: b.backgroundColor || "#00a19b",
                        textColor: b.textColor || "#ffffff",
                        borderColor: b.borderColor || "#008f8a",
                        actionDefinitionId: b.actionDefinitionId || null,
                        actionUrl: b.actionUrl || "",
                        actionTarget: b.actionTarget || "_self"
                    })) : []
                };
            }

            function openPicker(idx) {
                pickerTargetIndex = idx;
                if (!modal || !modalGrid) return;
                modalGrid.innerHTML = "";
                if (!pageMedia.length) {
                    modalGrid.innerHTML = '<p class="text-sm col-span-3">Bu sayfaya bağlı görsel yok.</p>';
                } else {
                    pageMedia.forEach((m) => {
                        const b = document.createElement("button");
                        b.type = "button";
                        b.className = "rounded border overflow-hidden hover:ring-2 ring-brand-lightAccent";
                        const img = document.createElement("img");
                        img.src = m.filePath;
                        img.alt = m.displayName || "";
                        img.className = "h-24 w-full object-cover";
                        b.appendChild(img);
                        b.addEventListener("click", () => submitPick(m.mediaFileId));
                        modalGrid.appendChild(b);
                    });
                }
                modal.classList.remove("hidden");
                modal.classList.add("flex");
            }

            function submitPick(mediaFileId) {
                const card = state.cards[pickerTargetIndex];
                if (!card) return;
                const form = document.createElement("form");
                form.method = "post";
                form.action = "@Url.Action("SetCardMedia", "Cards")";
                const t = document.createElement("input");
                t.type = "hidden"; t.name = "__RequestVerificationToken"; t.value = token;
                form.appendChild(t);
                [["pageId", String(pageId)], ["cardComponentId", String(card.cardComponentId)], ["mediaFileId", String(mediaFileId)]].forEach(([n, v]) => {
                    const i = document.createElement("input");
                    i.type = "hidden"; i.name = n; i.value = v;
                    form.appendChild(i);
                });
                document.body.appendChild(form);
                form.submit();
            }

            function closePicker() {
                if (!modal) return;
                modal.classList.add("hidden");
                modal.classList.remove("flex");
            }

            closeModal?.addEventListener("click", closePicker);
            modal?.addEventListener("click", (e) => { if (e.target === modal) closePicker(); });

            function addPresetFromDefinition(def) {
                const previewUrl = (def.previewImageUrl || "").trim();
                const m = pickRandomPageMedia();
                const mediaPath = m ? m.filePath : previewUrl;
                const mediaId = m ? m.mediaFileId : null;
                state.cards.push({
                    componentId: 0,
                    cardComponentId: 0,
                    displayOrder: state.cards.length + 1,
                    x: 0,
                    y: 0,
                    width: 320,
                    height: 320,
                    isVisible: true,
                    cardDefinitionId: def.id || 0,
                    title: loremTitle,
                    subtitle: "",
                    description: loremBody,
                    htmlFragment: "",
                    mediaFileId: mediaId,
                    mediaFilePath: mediaPath,
                    showImage: true,
                    showButton: true,
                    backgroundColor: "#1a1a1f",
                    textColor: "#f4f4f5",
                    borderColor: "#3f3f46",
                    buttons: [{
                        id: 0,
                        displayOrder: 1,
                        text: loremBtn,
                        icon: "",
                        backgroundColor: "#c4b5fd",
                        textColor: "#ffffff",
                        borderColor: "transparent",
                        actionDefinitionId: null,
                        actionUrl: "",
                        actionTarget: "_self"
                    }]
                });
                selectedIndex = state.cards.length - 1;
                render();
            }

            if (presetsHost && Array.isArray(cardDefinitions)) {
                cardDefinitions.forEach((def) => {
                    const b = document.createElement("button");
                    b.type = "button";
                    b.className = "rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder bg-white px-3 py-1.5 text-xs font-medium text-gray-900 hover:bg-gray-50";
                    b.textContent = def.name || ("#" + def.id);
                    b.title = def.code ? String(def.code) : "";
                    b.addEventListener("click", () => addPresetFromDefinition(def));
                    presetsHost.appendChild(b);
                });
            }

            function render() {
                canvas.innerHTML = "";
                state.cards.forEach((card, idx) => {
                    const el = document.createElement("div");
                    el.dataset.index = String(idx);
                    el.className = "relative w-full min-h-[180px] rounded-xl border-2 overflow-hidden flex flex-col cursor-pointer shadow-sm " +
                        (idx === selectedIndex ? "border-brand-lightAccent ring-2 ring-brand-lightAccent" : "border-brand-lightBorder dark:border-brand-darkBorder");
                    el.style.backgroundColor = card.backgroundColor || "#1a1a1f";
                    el.style.color = card.textColor || "#f4f4f5";

                    if (card.htmlFragment) {
                        const wrap = document.createElement("div");
                        wrap.className = "prose prose-sm max-w-none text-xs overflow-auto max-h-56 rounded-md p-2 flex-1";
                        wrap.style.colorScheme = "light";
                        wrap.style.backgroundColor = "#ffffff";
                        wrap.style.color = "#111827";
                        wrap.innerHTML = card.htmlFragment;
                        el.appendChild(wrap);
                    } else {
                        if (card.showImage) {
                            const imgWrap = document.createElement("div");
                            imgWrap.className = "w-full aspect-[16/10] shrink-0 overflow-hidden bg-neutral-800";
                            if (card.mediaFilePath) {
                                const img = document.createElement("img");
                                img.src = card.mediaFilePath;
                                img.className = "h-full w-full object-cover";
                                img.alt = "";
                                imgWrap.appendChild(img);
                            } else {
                                imgWrap.textContent = "Görsel yok";
                                imgWrap.classList.add("flex", "items-center", "justify-center", "text-xs", "text-neutral-500");
                            }
                            imgWrap.addEventListener("dblclick", (e) => {
                                e.stopPropagation();
                                if (!card.htmlFragment && card.cardComponentId > 0) openPicker(idx);
                            });
                            el.appendChild(imgWrap);
                        }
                        const body = document.createElement("div");
                        body.className = "flex flex-col flex-1 gap-1.5 p-2.5 min-h-0";
                        const title = document.createElement("div");
                        title.className = "font-semibold text-sm leading-snug line-clamp-2";
                        title.style.color = card.textColor || "#f4f4f5";
                        title.textContent = card.title || "Kart";
                        body.appendChild(title);
                        const desc = document.createElement("div");
                        desc.className = "text-xs leading-relaxed line-clamp-4 opacity-90";
                        desc.style.color = card.textColor || "#f4f4f5";
                        desc.textContent = card.description || "";
                        body.appendChild(desc);
                        const primary = (card.showButton && card.buttons && card.buttons.length)
                            ? [...card.buttons].sort((a, b) => (a.displayOrder || 0) - (b.displayOrder || 0))[0]
                            : null;
                        if (primary && primary.text) {
                            const foot = document.createElement("div");
                            foot.className = "mt-auto pt-1 flex justify-end";
                            const btn = document.createElement("span");
                            btn.className = "inline-flex items-center gap-1 rounded-lg px-2.5 py-1 text-[11px] font-semibold";
                            btn.style.backgroundColor = primary.backgroundColor || "#c4b5fd";
                            btn.style.color = primary.textColor || "#ffffff";
                            btn.textContent = primary.text + " ↗";
                            foot.appendChild(btn);
                            body.appendChild(foot);
                        }
                        el.appendChild(body);
                    }

                    el.addEventListener("click", () => {
                        selectedIndex = idx;
                        render();
                    });

                    canvas.appendChild(el);
                });
            }

            addHtmlBtn?.addEventListener("click", () => {
                const html = (htmlInput?.value || "").trim();
                if (!html) return;
                state.cards.push({
                    componentId: 0,
                    cardComponentId: 0,
                    displayOrder: state.cards.length + 1,
                    x: 0,
                    y: 0,
                    width: 320,
                    height: 320,
                    isVisible: true,
                    cardDefinitionId: 0,
                    title: "",
                    subtitle: "",
                    description: "",
                    htmlFragment: html,
                    mediaFileId: null,
                    mediaFilePath: "",
                    showImage: false,
                    showButton: false,
                    backgroundColor: "#1a1a1f",
                    textColor: "#f4f4f5",
                    borderColor: "#3f3f46",
                    buttons: []
                });
                htmlInput.value = "";
                selectedIndex = state.cards.length - 1;
                render();
            });

            removeBtn?.addEventListener("click", () => {
                if (selectedIndex < 0) return;
                state.cards.splice(selectedIndex, 1);
                selectedIndex = Math.min(selectedIndex, state.cards.length - 1);
                render();
            });

            saveBtn.addEventListener("click", () => {
                const payload = state.cards.map((c, index) => ({
                    componentId: c.componentId || 0,
                    cardComponentId: c.cardComponentId || 0,
                    displayOrder: index + 1,
                    x: c.x || 0,
                    y: c.y || 0,
                    width: c.width || 320,
                    height: c.height || 320,
                    isVisible: c.isVisible !== false,
                    cardDefinitionId: c.cardDefinitionId || 0,
                    title: c.title || "",
                    subtitle: c.subtitle || "",
                    description: c.description || "",
                    htmlFragment: c.htmlFragment || "",
                    mediaFileId: c.mediaFileId,
                    showImage: !!c.showImage,
                    showButton: c.htmlFragment ? false : !!c.showButton,
                    backgroundColor: c.backgroundColor,
                    textColor: c.textColor,
                    borderColor: c.borderColor,
                    buttons: (c.buttons || []).map((b, bi) => ({
                        id: b.id || 0,
                        displayOrder: bi + 1,
                        text: b.text || "",
                        icon: b.icon || "",
                        backgroundColor: b.backgroundColor,
                        textColor: b.textColor,
                        borderColor: b.borderColor,
                        actionDefinitionId: b.actionDefinitionId,
                        actionUrl: b.actionUrl || "",
                        actionTarget: b.actionTarget || "_self"
                    }))
                }));
                payloadInput.value = JSON.stringify(payload);
                saveForm.submit();
            });

            render();
        })();
    </script>
}
