@using System.Text.Encodings.Web
@using System.Text.Json
@model TrivaWebPage.ViewModels.Admin.TemplateCanvasViewModel
@{
    ViewData["Title"] = "SayfaDuzenle";
    var activePage = Model.ActivePage;
    string? safeTemplateCanvasMediaJson = null;
    string? safeLibraryMediaJson = null;
    if (activePage is not null)
    {
        var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
        safeTemplateCanvasMediaJson = JavaScriptEncoder.Default.Encode(JsonSerializer.Serialize(Model.PageMedia, jsonOpts));
        safeLibraryMediaJson = JavaScriptEncoder.Default.Encode(JsonSerializer.Serialize(Model.LibraryMedia, jsonOpts));
    }
}

<div class="max-w-7xl mx-auto space-y-5">
    <div class="flex items-center justify-between gap-3">
        <h1 class="text-2xl font-semibold text-brand-lightText dark:text-brand-darkText">Sayfa Düzenle</h1>
        @if (activePage is not null)
        {
            <div class="flex gap-2">
                <form asp-action="Reset" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="pageId" value="@activePage.PageId" />
                    <button type="submit" class="rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-4 py-2 text-sm hover:bg-black/5 dark:hover:bg-white/5">Varsayılana dön</button>
                </form>
                <button type="button" id="saveCanvasBtn" class="rounded-lg bg-brand-lightAccent dark:bg-brand-darkAccent px-4 py-2 text-sm font-medium text-white hover:opacity-90">Kaydet</button>
            </div>
        }
    </div>

    @if (TempData["TemplateCanvasError"] is string err)
    {
        <div class="rounded-xl border border-red-300/80 bg-red-50 px-4 py-3 text-sm text-red-900 dark:border-red-800 dark:bg-red-950/50 dark:text-red-100">@err</div>
    }
    @if (TempData["TemplateCanvasMessage"] is string ok)
    {
        <div class="rounded-xl border border-emerald-300/80 bg-emerald-50 px-4 py-3 text-sm text-emerald-900 dark:border-emerald-800 dark:bg-emerald-950/50 dark:text-emerald-100">@ok</div>
    }

    <div class="flex flex-wrap gap-2 border-b border-brand-lightBorder dark:border-brand-darkBorder pb-2">
        @foreach (var p in Model.Pages)
        {
            var active = Model.ActivePageId == p.Id;
            <a asp-action="Index" asp-route-pageId="@p.Id"
               class="rounded-t-lg px-4 py-2 text-sm font-medium transition max-w-[12rem] truncate @(active
                   ? "bg-brand-lightPanel dark:bg-brand-darkPanel text-brand-lightText dark:text-brand-darkText border border-b-0 border-brand-lightBorder dark:border-brand-darkBorder -mb-px"
                   : "text-brand-lightMuted dark:text-brand-darkMuted hover:text-brand-lightText dark:hover:text-brand-darkText")"
               title="@p.Name">@p.Name</a>
        }
    </div>

    @if (activePage is null)
    {
        <div class="rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-6 text-sm text-brand-lightMuted dark:text-brand-darkMuted">
            Düzenlenecek bir sayfa bulunamadı.
        </div>
    }
    else
    {
        <form id="saveCanvasForm" asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PageId" value="@activePage.PageId" />
            <input type="hidden" name="ColorPaletteId" id="canvasPaletteIdInput" value="@(activePage.Palette?.Id)" />
            <input type="hidden" name="HtmlContent" id="canvasHtmlInput" />
            <input type="hidden" name="HtmlContentTablet" id="canvasHtmlTabletInput" />
            <input type="hidden" name="HtmlContentPhone" id="canvasHtmlPhoneInput" />
        </form>

        <div class="grid min-w-0 gap-4 lg:grid-cols-[minmax(0,280px)_minmax(0,1fr)]">
            <section id="templateCanvasOptionsPanel" class="min-w-0 rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-4 space-y-3">
                <div>
                    <p class="text-xs uppercase tracking-wide text-brand-lightMuted dark:text-brand-darkMuted">Sayfa</p>
                    <p class="font-medium">@activePage.PageName</p>
                    <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">@activePage.PageWidth x @activePage.PageHeight px</p>
                    <p class="mt-1 text-xs text-brand-lightMuted dark:text-brand-darkMuted">
                        Şablon içi sayfa: @(string.IsNullOrWhiteSpace(activePage.TemplatePageName) ? "Seçili değil" : activePage.TemplatePageName)
                    </p>
                </div>

                <div class="space-y-2 border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3">
                    <button type="button" id="deleteNodeBtn" class="w-full rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 text-sm hover:bg-black/5 dark:hover:bg-white/5">Seçili öğeyi sil</button>
                    <button type="button" id="clearSelectionBtn" class="w-full rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 text-sm hover:bg-black/5 dark:hover:bg-white/5">Seçimi temizle</button>
                </div>

                <div class="space-y-2 border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3">
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Hazır kart ekle</label>
                    <div id="cardTypeChips" class="flex flex-wrap gap-1.5 max-h-32 overflow-y-auto rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder bg-white/50 dark:bg-black/20 p-2"></div>
                    <p class="text-[11px] text-brand-lightMuted dark:text-brand-darkMuted">Karta tıklayınca canvas’a eklenir.</p>
                </div>

                <div class="space-y-2 border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3">
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Metin</label>
                    <textarea id="nodeTextInput" class="w-full rounded border px-2 py-1.5 text-black text-sm" rows="4"></textarea>
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Link (href) — önizlemede tıklanmaz, canlı sayfada çalışır</label>
                    <input id="nodeHrefInput" class="w-full rounded border px-2 py-1.5 text-black text-sm" placeholder="/yol veya https://..." />
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Resim (src / URL)</label>
                    <input id="nodeSrcInput" type="text" class="w-full rounded border px-2 py-1.5 text-black text-sm" placeholder="https://... veya /uploads/..." autocomplete="off" />
                    <div class="flex flex-wrap gap-2">
                        <button type="button" id="openLibraryMediaModalBtn" class="shrink-0 rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-2 py-1.5 text-xs font-medium hover:bg-black/5 dark:hover:bg-white/5" title="Tüm yüklenen resimler (Resimler)">Yüklenen Resimler</button>
                    </div>
                    <p class="text-[11px] text-brand-lightMuted dark:text-brand-darkMuted">Adresi buraya yazabilir veya modallardan seçebilirsiniz.</p>
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Alt metin (alt)</label>
                    <input id="nodeAltInput" class="w-full rounded border px-2 py-1.5 text-black text-sm" />
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Class</label>
                    <input id="nodeClassInput" class="w-full rounded border px-2 py-1.5 text-black text-sm" />
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Style</label>
                    <textarea id="nodeStyleInput" class="w-full rounded border px-2 py-1.5 text-black text-sm" rows="3"></textarea>
                </div>
                <div id="canvasNodeColorsPanel" class="space-y-2 border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3 scroll-mt-3 rounded-lg transition-shadow duration-500">
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Renk düzenleme</label>
                    <div class="grid grid-cols-3 gap-2">
                        <div>
                            <label class="text-[11px] text-brand-lightMuted dark:text-brand-darkMuted">Arka plan</label>
                            <input id="nodeBackgroundColorInput" type="color" class="mt-1 h-9 w-full rounded border bg-white p-1" value="#ffffff" />
                        </div>
                        <div>
                            <label class="text-[11px] text-brand-lightMuted dark:text-brand-darkMuted">Yazı</label>
                            <input id="nodeTextColorInput" type="color" class="mt-1 h-9 w-full rounded border bg-white p-1" value="#111111" />
                        </div>
                        <div>
                            <label class="text-[11px] text-brand-lightMuted dark:text-brand-darkMuted">Kenarlık</label>
                            <input id="nodeBorderColorInput" type="color" class="mt-1 h-9 w-full rounded border bg-white p-1" value="#d1d5db" />
                        </div>
                    </div>
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Sayfa arka planı</label>
                    <input id="pageBackgroundColorInput" type="color" class="h-9 w-full rounded border bg-white p-1" value="#ffffff" />
                </div>

                <div class="space-y-2 border-t border-brand-lightBorder dark:border-brand-darkBorder pt-3">
                    <label class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Hazır renk paleti</label>
                    <select id="paletteSelect" class="w-full rounded border px-2 py-1.5 text-black text-sm">
                        <option value="">Palet seçin</option>
                        @foreach (var palette in Model.AvailablePalettes)
                        {
                            var isSelected = activePage.Palette?.Id == palette.Id;
                            <option value="@palette.Id"
                                    data-primary="@palette.PrimaryHex"
                                    data-secondary="@palette.SecondaryHex"
                                    data-muted="@palette.MutedHex"
                                    data-accent="@palette.AccentHex"
                                    selected="@(isSelected ? "selected" : null)">
                                @palette.Name
                            </option>
                        }
                    </select>
                    <div id="activePaletteSwatches" class="flex gap-2">
                        <span id="swatchPrimary" class="h-6 w-8 rounded border border-black/10" title="Primary"></span>
                        <span id="swatchSecondary" class="h-6 w-8 rounded border border-black/10" title="Secondary"></span>
                        <span id="swatchMuted" class="h-6 w-8 rounded border border-black/10" title="Muted"></span>
                        <span id="swatchAccent" class="h-6 w-8 rounded border border-black/10" title="Accent"></span>
                    </div>
                </div>
            </section>

            <section class="min-w-0 rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel p-4 sm:p-6 overflow-auto space-y-3">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="text-xs uppercase tracking-wide text-brand-lightMuted dark:text-brand-darkMuted">Önizleme</span>
                    <div class="flex flex-wrap gap-1 rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder p-1 bg-white/40 dark:bg-black/20">
                        <button type="button" class="canvas-bp-tab rounded-md px-3 py-1.5 text-xs font-medium bg-brand-lightAccent dark:bg-brand-darkAccent text-white" data-bp="desktop">Masaüstü</button>
                        <button type="button" class="canvas-bp-tab rounded-md px-3 py-1.5 text-xs font-medium text-brand-lightText dark:text-brand-darkText hover:bg-black/5 dark:hover:bg-white/10" data-bp="tablet">Tablet</button>
                        <button type="button" class="canvas-bp-tab rounded-md px-3 py-1.5 text-xs font-medium text-brand-lightText dark:text-brand-darkText hover:bg-black/5 dark:hover:bg-white/10" data-bp="phone">Telefon</button>
                    </div>
                </div>
                <div id="canvasFrameOuter" class="mx-auto flex min-h-0 min-w-0 justify-center overflow-auto rounded-xl border border-dashed border-brand-lightBorder dark:border-brand-darkBorder bg-neutral-100/80 dark:bg-black/30 p-3" style="max-height: min(85vh, 920px);">
                    <div id="canvasFrameScaleWrap" class="relative origin-top" style="transform: scale(1);">
                        <iframe id="canvasFrame"
                                class="block rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder bg-white shadow-sm"
                                style="width: @(activePage.PageWidth)px; height: @(activePage.PageHeight)px;"></iframe>
                    </div>
                </div>
            </section>
        </div>

        <div id="canvasMediaModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" role="dialog" aria-modal="true" aria-labelledby="canvasMediaModalTitle">
            <div class="max-h-[90vh] w-full max-w-lg overflow-hidden rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel shadow-lg flex flex-col" onclick="event.stopPropagation()">
                <div class="flex items-center justify-between gap-2 border-b border-brand-lightBorder dark:border-brand-darkBorder px-4 py-3">
                    <h2 id="canvasMediaModalTitle" class="text-sm font-semibold text-brand-lightText dark:text-brand-darkText">Sayfa görselleri</h2>
                    <button type="button" id="closeCanvasMediaModalBtn" class="rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-2 py-1 text-xs hover:bg-black/5 dark:hover:bg-white/5">Kapat</button>
                </div>
                <div class="space-y-3 overflow-y-auto p-4">
                    <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Yükleyin veya küçük resme tıklayarak seçili öğedeki resme yerleştirin (img veya içinde img olan blok).</p>
                    <form id="canvasMediaUploadForm" class="space-y-2">
                        <input type="file" id="canvasMediaFileInput" name="file" accept=".jpg,.jpeg,.png,.gif,.webp" class="block w-full text-xs text-black" />
                        <button type="submit" class="w-full rounded-lg bg-brand-lightAccent dark:bg-brand-darkAccent px-3 py-2 text-xs font-medium text-white hover:opacity-90">Yükle (sayfaya bağla)</button>
                    </form>
                    <p id="canvasMediaUploadError" class="hidden text-xs text-red-700 dark:text-red-300"></p>
                    <div id="canvasMediaGrid" class="grid grid-cols-3 gap-2"></div>
                </div>
            </div>
        </div>

        <div id="libraryMediaModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 p-4" role="dialog" aria-modal="true" aria-labelledby="libraryMediaModalTitle">
            <div class="max-h-[90vh] w-full max-w-3xl overflow-hidden rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-brand-lightPanel dark:bg-brand-darkPanel shadow-lg flex flex-col" onclick="event.stopPropagation()">
                <div class="flex items-center justify-between gap-2 border-b border-brand-lightBorder dark:border-brand-darkBorder px-4 py-3">
                    <h2 id="libraryMediaModalTitle" class="text-sm font-semibold text-brand-lightText dark:text-brand-darkText">Resim kütüphanesi</h2>
                    <button type="button" id="closeLibraryMediaModalBtn" class="rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder px-2 py-1 text-xs hover:bg-black/5 dark:hover:bg-white/5">Kapat</button>
                </div>
                <div class="space-y-3 overflow-y-auto p-4">
                    <p class="text-xs text-brand-lightMuted dark:text-brand-darkMuted">Resimler ekranındaki gibi tüm yüklenen dosyalar. Küçük resme tıklayınca seçili öğedeki görsel güncellenir. İsterseniz soldaki alana harici URL de yazabilirsiniz.</p>
                    <form id="libraryMediaUploadForm" class="space-y-2">
                        <input type="file" id="libraryMediaFileInput" name="file" accept=".jpg,.jpeg,.png,.gif,.webp" class="block w-full text-xs text-black" />
                        <button type="submit" class="w-full rounded-lg bg-brand-lightAccent dark:bg-brand-darkAccent px-3 py-2 text-xs font-medium text-white hover:opacity-90">Resim yükle</button>
                    </form>
                    <p id="libraryMediaUploadError" class="hidden text-xs text-red-700 dark:text-red-300"></p>
                    <div id="libraryMediaGrid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"></div>
                </div>
            </div>
        </div>
    }
</div>

@if (activePage is not null)
{
    <script>
        (function () {
            const htmlByBp = {
                desktop: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(activePage.HtmlContent ?? "")),
                tablet: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(activePage.HtmlContentTablet ?? "")),
                phone: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(activePage.HtmlContentPhone ?? ""))
            };
            const initialPalette = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(activePage.Palette));
            const pageMedia = JSON.parse("@Html.Raw(safeTemplateCanvasMediaJson)");
            let libraryMedia = JSON.parse("@Html.Raw(safeLibraryMediaJson)");
            const pageId = @activePage.PageId;
            const pageDims = { w: @activePage.PageWidth, h: @activePage.PageHeight };
            const previewDims = {
                desktop: { w: pageDims.w, h: pageDims.h },
                tablet: { w: 768, h: 1024 },
                phone: { w: 390, h: 844 }
            };
            const mediaUploadUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("UploadMedia", "TemplateCanvas")));
            const libraryMediaUploadUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("UploadLibraryMedia", "TemplateCanvas")));
            const cardDefinitionsListUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("ListCardDefinitions", "TemplateCanvas")));
            const frame = document.getElementById("canvasFrame");
            const frameOuter = document.getElementById("canvasFrameOuter");
            const frameScaleWrap = document.getElementById("canvasFrameScaleWrap");
            const saveBtn = document.getElementById("saveCanvasBtn");
            const saveForm = document.getElementById("saveCanvasForm");
            const htmlInput = document.getElementById("canvasHtmlInput");
            const htmlTabletInput = document.getElementById("canvasHtmlTabletInput");
            const htmlPhoneInput = document.getElementById("canvasHtmlPhoneInput");
            const paletteIdInput = document.getElementById("canvasPaletteIdInput");
            const deleteNodeBtn = document.getElementById("deleteNodeBtn");
            const clearSelectionBtn = document.getElementById("clearSelectionBtn");
            const cardTypeChips = document.getElementById("cardTypeChips");
            const textInput = document.getElementById("nodeTextInput");
            const hrefInput = document.getElementById("nodeHrefInput");
            const srcInput = document.getElementById("nodeSrcInput");
            const altInput = document.getElementById("nodeAltInput");
            const classInput = document.getElementById("nodeClassInput");
            const styleInput = document.getElementById("nodeStyleInput");
            const nodeBackgroundColorInput = document.getElementById("nodeBackgroundColorInput");
            const nodeTextColorInput = document.getElementById("nodeTextColorInput");
            const nodeBorderColorInput = document.getElementById("nodeBorderColorInput");
            const pageBackgroundColorInput = document.getElementById("pageBackgroundColorInput");
            const paletteSelect = document.getElementById("paletteSelect");
            const swatchPrimary = document.getElementById("swatchPrimary");
            const swatchSecondary = document.getElementById("swatchSecondary");
            const swatchMuted = document.getElementById("swatchMuted");
            const swatchAccent = document.getElementById("swatchAccent");
            const canvasMediaModal = document.getElementById("canvasMediaModal");
            const closeCanvasMediaModalBtn = document.getElementById("closeCanvasMediaModalBtn");
            const canvasMediaUploadForm = document.getElementById("canvasMediaUploadForm");
            const canvasMediaFileInput = document.getElementById("canvasMediaFileInput");
            const canvasMediaGrid = document.getElementById("canvasMediaGrid");
            const canvasMediaUploadError = document.getElementById("canvasMediaUploadError");
            const libraryMediaModal = document.getElementById("libraryMediaModal");
            const openLibraryMediaModalBtn = document.getElementById("openLibraryMediaModalBtn");
            const closeLibraryMediaModalBtn = document.getElementById("closeLibraryMediaModalBtn");
            const libraryMediaUploadForm = document.getElementById("libraryMediaUploadForm");
            const libraryMediaFileInput = document.getElementById("libraryMediaFileInput");
            const libraryMediaGrid = document.getElementById("libraryMediaGrid");
            const libraryMediaUploadError = document.getElementById("libraryMediaUploadError");
            const canvasNodeColorsPanel = document.getElementById("canvasNodeColorsPanel");
            if (!frame || !saveBtn || !saveForm || !htmlInput || !htmlTabletInput || !htmlPhoneInput) return;

            const requestToken = saveForm.querySelector('input[name="__RequestVerificationToken"]')?.value || "";

            let selectedNode = null;
            let selectedOutline = null;
            let activePalette = initialPalette;
            let activeBp = "desktop";

            function escapeRegExp(text) {
                return String(text).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
            }

            function escapeHtml(s) {
                return String(s ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/\"/g, "&quot;");
            }

            function flushHtmlStore() {
                const doc = frame.contentDocument;
                if (!doc) return;
                doc.querySelectorAll(".__canvas-selected").forEach((x) => x.classList.remove("__canvas-selected"));
                htmlByBp[activeBp] = doc.documentElement.outerHTML;
            }

            function applyPalette(doc, palette) {
                if (!palette || !doc?.documentElement) return;
                const root = doc.documentElement;
                root.style.setProperty("--color-primary", palette.PrimaryHex || "#111111");
                root.style.setProperty("--color-secondary", palette.SecondaryHex || "#333333");
                root.style.setProperty("--color-muted", palette.MutedHex || "#777777");
                root.style.setProperty("--color-accent", palette.AccentHex || "#00a19b");
                root.style.setProperty("--canvas-select-color", palette.AccentHex || "#00a19b");
                replaceInlineColors(doc.body, {
                    [palette.PrimaryHex]: "var(--color-primary)",
                    [palette.SecondaryHex]: "var(--color-secondary)",
                    [palette.MutedHex]: "var(--color-muted)",
                    [palette.AccentHex]: "var(--color-accent)"
                });
                if (doc.body) {
                    doc.body.style.backgroundColor = palette.SecondaryHex || "#ffffff";
                }
            }

            function replaceInlineColors(scope, paletteMap) {
                if (!scope) return;
                const defaults = {
                    "#000000": "var(--color-primary)",
                    "#111111": "var(--color-primary)",
                    "#222222": "var(--color-secondary)",
                    "#333333": "var(--color-secondary)",
                    "#666666": "var(--color-muted)",
                    "#777777": "var(--color-muted)",
                    "#999999": "var(--color-muted)",
                    "#ffffff": "var(--color-accent)"
                };
                const merged = { ...defaults };
                Object.entries(paletteMap || {}).forEach(([hex, cssVar]) => {
                    if (!hex || !cssVar) return;
                    merged[String(hex).toLowerCase()] = cssVar;
                });

                const nodes = scope.querySelectorAll("*");
                nodes.forEach((node) => {
                    const inlineStyle = node.getAttribute("style");
                    if (!inlineStyle) return;
                    let updatedStyle = inlineStyle;
                    Object.entries(merged).forEach(([hex, cssVar]) => {
                        const regex = new RegExp(escapeRegExp(hex), "ig");
                        updatedStyle = updatedStyle.replace(regex, cssVar);
                    });
                    if (updatedStyle !== inlineStyle) {
                        node.setAttribute("style", updatedStyle);
                    }
                });
            }

            function wireFrameDocument(doc) {
                const style = doc.createElement("style");
                style.textContent = ".__canvas-selected{outline:2px solid var(--canvas-select-color, #00a19b) !important;outline-offset:2px !important;opacity:1 !important;}";
                doc.head.appendChild(style);
                applyPalette(doc, activePalette);
                if (doc.body) {
                    const pos = doc.defaultView?.getComputedStyle(doc.body)?.position;
                    if (!pos || pos === "static") {
                        doc.body.style.position = "relative";
                    }
                }
                doc.addEventListener("click", (e) => {
                    e.stopPropagation();
                    const anchor = e.target && typeof e.target.closest === "function" ? e.target.closest("a") : null;
                    if (anchor) {
                        e.preventDefault();
                        selectNode(anchor);
                        return;
                    }
                    selectNode(e.target);
                }, true);
            }

            function loadHtmlIntoFrame(htmlString) {
                const doc = frame.contentDocument;
                doc.open();
                doc.write(htmlString || "");
                doc.close();
                wireFrameDocument(doc);
            }

            function resizePreviewForBp() {
                const d = previewDims[activeBp];
                if (!d || !frame || !frameOuter || !frameScaleWrap) return;
                frame.style.width = d.w + "px";
                frame.style.height = d.h + "px";
                const rw = Math.max(120, frameOuter.clientWidth - 24);
                const rh = Math.max(120, frameOuter.clientHeight - 24);
                const sx = rw / d.w;
                const sy = rh / d.h;
                const s = Math.min(1, sx, sy);
                frameScaleWrap.style.transform = "scale(" + s + ")";
                frameScaleWrap.style.transformOrigin = "top center";
            }

            function updateBpTabStyles() {
                document.querySelectorAll(".canvas-bp-tab").forEach((btn) => {
                    const on = btn.getAttribute("data-bp") === activeBp;
                    btn.classList.toggle("bg-brand-lightAccent", on);
                    btn.classList.toggle("dark:bg-brand-darkAccent", on);
                    btn.classList.toggle("text-white", on);
                    btn.classList.toggle("text-brand-lightText", !on);
                    btn.classList.toggle("dark:text-brand-darkText", !on);
                });
            }

            function switchBreakpoint(bp) {
                if (bp === activeBp) return;
                flushHtmlStore();
                activeBp = bp;
                loadHtmlIntoFrame(htmlByBp[activeBp] || "");
                updateBpTabStyles();
                window.requestAnimationFrame(() => {
                    resizePreviewForBp();
                    clearSelection();
                    syncInputsFromNode();
                });
            }

            function selectNode(node) {
                if (!node || node.tagName === "HTML" || node.tagName === "BODY" || node.tagName === "HEAD") return;
                clearSelection();
                selectedNode = node;
                selectedOutline = node;
                selectedOutline.classList.add("__canvas-selected");
                syncInputsFromNode();
            }

            function clearSelection() {
                if (selectedOutline) selectedOutline.classList.remove("__canvas-selected");
                selectedNode = null;
                selectedOutline = null;
            }

            function syncInputsFromNode() {
                if (!selectedNode) {
                    textInput.value = "";
                    hrefInput.value = "";
                    if (srcInput) srcInput.value = "";
                    altInput.value = "";
                    classInput.value = "";
                    styleInput.value = "";
                    nodeBackgroundColorInput.value = "#ffffff";
                    nodeTextColorInput.value = "#111111";
                    nodeBorderColorInput.value = "#d1d5db";
                    return;
                }
                textInput.value = selectedNode.textContent || "";
                hrefInput.value = selectedNode.getAttribute?.("href") || "";
                if (srcInput) srcInput.value = selectedNode.getAttribute?.("src") || "";
                altInput.value = selectedNode.getAttribute?.("alt") || "";
                classInput.value = (selectedNode.className || "").split(/\s+/).filter((c) => c).join(" ");
                styleInput.value = selectedNode.getAttribute?.("style") || "";
                const computed = frame.contentWindow?.getComputedStyle(selectedNode);
                nodeBackgroundColorInput.value = toHexColor(computed?.backgroundColor, "#ffffff");
                nodeTextColorInput.value = toHexColor(computed?.color, "#111111");
                nodeBorderColorInput.value = toHexColor(computed?.borderColor, "#d1d5db");
            }

            function applyInputsToNode() {
                if (!selectedNode) return;
                const isContentNode = selectedNode.childNodes.length === 1 && selectedNode.childNodes[0].nodeType === Node.TEXT_NODE;
                if (isContentNode || selectedNode.tagName === "P" || selectedNode.tagName === "SPAN" || selectedNode.tagName === "H1" || selectedNode.tagName === "H2" || selectedNode.tagName === "H3" || selectedNode.tagName === "H4" || selectedNode.tagName === "H5" || selectedNode.tagName === "H6" || selectedNode.tagName === "A" || selectedNode.tagName === "BUTTON" || selectedNode.tagName === "LI") {
                    selectedNode.textContent = textInput.value || "";
                }
                setAttr(selectedNode, "href", hrefInput.value);
                setAttr(selectedNode, "src", srcInput.value);
                setAttr(selectedNode, "alt", altInput.value);
                setAttr(selectedNode, "style", styleInput.value);
                selectedNode.className = classInput.value || "";
                styleInput.value = selectedNode.getAttribute?.("style") || "";
            }

            function applySelectedNodeColors() {
                if (!selectedNode) return;
                selectedNode.style.backgroundColor = nodeBackgroundColorInput.value || "";
                selectedNode.style.color = nodeTextColorInput.value || "";
                selectedNode.style.borderColor = nodeBorderColorInput.value || "";
                styleInput.value = selectedNode.getAttribute?.("style") || "";
            }

            function applyPageBackgroundColor() {
                const doc = frame.contentDocument;
                if (!doc?.body) return;
                doc.body.style.backgroundColor = pageBackgroundColorInput.value || "";
            }

            function toHexColor(colorValue, fallback) {
                if (!colorValue) return fallback;
                if (String(colorValue).startsWith("#")) return colorValue;
                const match = String(colorValue).match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/i);
                if (!match) return fallback;
                const toHex = (v) => Number(v).toString(16).padStart(2, "0");
                return "#" + toHex(match[1]) + toHex(match[2]) + toHex(match[3]);
            }

            function setAttr(node, key, value) {
                if (!node || !node.setAttribute) return;
                if (!value) {
                    node.removeAttribute(key);
                    return;
                }
                node.setAttribute(key, value);
            }

            function renderInfoCard(card) {
                card.innerHTML = "<h3 style='margin:0 0 8px;font-size:20px;'>Bilgi Kartı</h3><p style='margin:0;'>Canvas içine eklenen örnek kart. İçeriği düzenleyebilirsiniz.</p>";
            }

            function renderCtaCard(card) {
                card.innerHTML = "<h3 style='margin:0 0 8px;font-size:20px;'>Başlık</h3><p style='margin:0 0 12px;'>Bu bir aksiyon kartıdır. Metni düzenleyebilirsiniz.</p><a href='#' style='display:inline-block;padding:10px 14px;border-radius:8px;background:var(--color-accent, #00a19b);color:#fff;text-decoration:none;'>Hemen Başla</a>";
            }

            function renderImageCard(card) {
                card.innerHTML = "<img src='https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800&q=80' alt='Kart görseli' style='width:100%;min-height:220px;max-height:320px;object-fit:cover;border-radius:20px;margin-bottom:16px;box-shadow:0 10px 30px rgba(15,23,42,.12);'/><h3 style='margin:0 0 10px;font-size:22px;font-weight:600;'>Görselli Kart</h3><p style='margin:0;line-height:1.6;color:#475569;font-size:15px;'>Görsel ve metin alanını güncelleyebilirsiniz.</p>";
            }

            function renderDefaultCard(card) {
                card.innerHTML = "<h3 style='margin:0 0 8px;font-size:20px;'>Kart</h3><p style='margin:0;'>Şablon içeriğini düzenleyebilirsiniz.</p>";
            }

            function renderMenuNavH(card) {
                card.innerHTML = "<nav style='display:flex;flex-wrap:wrap;gap:6px 12px;align-items:center;font-size:12px;font-weight:500;'><a href='#' style='color:var(--color-primary,#111);text-decoration:none;padding:4px 0;border-bottom:2px solid var(--color-accent,#00a19b);'>Ana</a><a href='#' style='color:var(--color-muted,#64748b);text-decoration:none;padding:4px 0;'>Hizmetler</a><a href='#' style='color:var(--color-muted,#64748b);text-decoration:none;padding:4px 0;'>İletişim</a><a href='#' style='color:var(--color-muted,#64748b);text-decoration:none;padding:4px 0;'>Blog</a></nav>";
            }

            function renderMenuNavV(card) {
                card.innerHTML = "<nav style='display:flex;flex-direction:column;gap:2px;font-size:12px;max-width:11rem;'><a href='#' style='padding:6px 10px;border-radius:6px;background:#f8fafc;color:#0f172a;text-decoration:none;'>Özet</a><a href='#' style='padding:6px 10px;border-radius:6px;color:#475569;text-decoration:none;'>Detaylar</a><a href='#' style='padding:6px 10px;border-radius:6px;color:#475569;text-decoration:none;'>Ayarlar</a><a href='#' style='padding:6px 10px;border-radius:6px;color:#475569;text-decoration:none;'>Çıkış</a></nav>";
            }

            function renderMenuPills(card) {
                card.innerHTML = "<nav style='display:flex;flex-wrap:wrap;gap:6px;font-size:11px;'><span style='padding:5px 12px;border-radius:9999px;background:var(--color-accent,#00a19b);color:#fff;font-weight:600;'>Tümü</span><a href='#' style='padding:5px 12px;border-radius:9999px;background:#e2e8f0;color:#334155;text-decoration:none;'>Yeni</a><a href='#' style='padding:5px 12px;border-radius:9999px;background:#e2e8f0;color:#334155;text-decoration:none;'>Popüler</a></nav>";
            }

            function renderMenuIconRow(card) {
                card.innerHTML = "<nav style='display:flex;gap:10px;align-items:center;font-size:10px;color:#64748b;'><a href='#' style='display:flex;flex-direction:column;align-items:center;gap:2px;text-decoration:none;color:inherit;min-width:44px;'><span style='font-size:16px;line-height:1;'>⌂</span><span>Ana</span></a><a href='#' style='display:flex;flex-direction:column;align-items:center;gap:2px;text-decoration:none;color:inherit;min-width:44px;'><span style='font-size:16px;line-height:1;'>☰</span><span>Menü</span></a><a href='#' style='display:flex;flex-direction:column;align-items:center;gap:2px;text-decoration:none;color:inherit;min-width:44px;'><span style='font-size:16px;line-height:1;'>✉</span><span>Mesaj</span></a></nav>";
            }

            const CARD_RENDERERS = {
                info: renderInfoCard,
                cta: renderCtaCard,
                image: renderImageCard,
                "menu-nav-h": renderMenuNavH,
                "menu-nav-v": renderMenuNavV,
                "menu-pills": renderMenuPills,
                "menu-icon-row": renderMenuIconRow,
                default: renderDefaultCard
            };

            function createCanvasCardElement(doc, cardCode) {
                const card = doc.createElement("div");
                if (!card) return null;
                card.className = "canvas-card";
                const key = String(cardCode || "").toLowerCase();
                const isMenu = key.startsWith("menu-");
                card.style.cssText = isMenu
                    ? "border:1px solid #e2e8f0;border-radius:12px;padding:8px 12px;margin:10px 0;background:#ffffff;color:#111111;box-shadow:0 2px 8px rgba(15,23,42,.06);max-width:22rem;"
                    : "border:1px solid #e2e8f0;border-radius:20px;padding:24px 28px;margin:20px 0;background:#ffffff;color:#111111;box-shadow:0 8px 24px rgba(15,23,42,.06);";
                card.setAttribute("data-card-template-code", key || "default");
                const render = CARD_RENDERERS[key] || CARD_RENDERERS.default;
                render(card);
                return card;
            }

            function addCardToCanvas(code) {
                const doc = frame.contentDocument;
                if (!doc?.body) return;
                const c = code || "info";
                const card = createCanvasCardElement(doc, c);
                if (!card) return;
                const target = selectedNode && selectedNode.appendChild ? selectedNode : doc.body;
                target.appendChild(card);
                selectNode(card);
            }

            async function loadCardDefinitionChips() {
                if (!cardTypeChips || !cardDefinitionsListUrl) return;
                try {
                    const res = await fetch(cardDefinitionsListUrl, { credentials: "same-origin" });
                    if (!res.ok) return;
                    const list = await res.json();
                    cardTypeChips.innerHTML = "";
                    (list || []).forEach((item) => {
                        const code = item.code || item.Code;
                        const name = item.name || item.Name;
                        if (!code) return;
                        const btn = document.createElement("button");
                        btn.type = "button";
                        btn.className = "rounded-md border border-brand-lightBorder dark:border-brand-darkBorder bg-white px-2 py-1 text-left text-[11px] font-medium text-gray-800 shadow-sm hover:border-brand-lightAccent dark:hover:border-brand-darkAccent";
                        btn.textContent = name || code;
                        btn.title = code;
                        btn.addEventListener("click", () => addCardToCanvas(code));
                        cardTypeChips.appendChild(btn);
                    });
                } catch {
                    /* ignore */
                }
            }

            function setPaletteSwatches(palette) {
                if (!swatchPrimary || !swatchSecondary || !swatchMuted || !swatchAccent) return;
                swatchPrimary.style.background = palette?.PrimaryHex || "#111111";
                swatchSecondary.style.background = palette?.SecondaryHex || "#333333";
                swatchMuted.style.background = palette?.MutedHex || "#777777";
                swatchAccent.style.background = palette?.AccentHex || "#00a19b";
            }

            function applyPaletteFromSelection() {
                const selectedOption = paletteSelect?.selectedOptions?.[0];
                if (!selectedOption || !selectedOption.value) {
                    activePalette = null;
                    if (paletteIdInput) paletteIdInput.value = "";
                    return;
                }
                activePalette = {
                    Id: Number(selectedOption.value),
                    Name: selectedOption.textContent?.trim() || "",
                    PrimaryHex: selectedOption.dataset.primary || "#111111",
                    SecondaryHex: selectedOption.dataset.secondary || "#333333",
                    MutedHex: selectedOption.dataset.muted || "#777777",
                    AccentHex: selectedOption.dataset.accent || "#00a19b"
                };
                if (paletteIdInput) paletteIdInput.value = selectedOption.value;
                const doc = frame.contentDocument;
                applyPalette(doc, activePalette);
                pageBackgroundColorInput.value = activePalette.SecondaryHex || "#ffffff";
                setPaletteSwatches(activePalette);
            }

            function resolveTargetImg() {
                if (!selectedNode || !frame.contentDocument) return null;
                if (selectedNode.tagName === "IMG") return selectedNode;
                return selectedNode.querySelector?.("img") || null;
            }

            function showCanvasMediaError(msg) {
                if (!canvasMediaUploadError) return;
                if (!msg) {
                    canvasMediaUploadError.classList.add("hidden");
                    canvasMediaUploadError.textContent = "";
                    return;
                }
                canvasMediaUploadError.textContent = msg;
                canvasMediaUploadError.classList.remove("hidden");
            }

            function renderCanvasMediaGrid() {
                if (!canvasMediaGrid) return;
                canvasMediaGrid.innerHTML = "";
                (pageMedia || []).forEach((item) => {
                    const wrap = document.createElement("button");
                    wrap.type = "button";
                    wrap.className = "group relative overflow-hidden rounded-lg border border-brand-lightBorder dark:border-brand-darkBorder bg-white text-left focus:outline-none focus:ring-2 focus:ring-brand-lightAccent";
                    wrap.title = item.displayName || item.filePath || "";
                    const thumb = document.createElement("img");
                    thumb.src = item.filePath || "";
                    thumb.alt = item.displayName || "";
                    thumb.className = "h-20 w-full object-cover";
                    thumb.loading = "lazy";
                    wrap.appendChild(thumb);
                    const cap = document.createElement("span");
                    cap.className = "block truncate px-1 py-0.5 text-[10px] text-brand-lightMuted dark:text-brand-darkMuted";
                    cap.textContent = item.displayName || "";
                    wrap.appendChild(cap);
                    wrap.addEventListener("click", () => {
                        const img = resolveTargetImg();
                        if (!img) {
                            alert("Önce canvas üzerinde bir resim (img) veya içinde resim olan bir öğe seçin.");
                            return;
                        }
                        img.setAttribute("src", item.filePath || "");
                        selectNode(img);
                        closeCanvasMediaModal();
                    });
                    canvasMediaGrid.appendChild(wrap);
                });
            }

            function closeCanvasMediaModal() {
                if (!canvasMediaModal) return;
                canvasMediaModal.classList.add("hidden");
                canvasMediaModal.classList.remove("flex");
            }

            function showLibraryMediaError(msg) {
                if (!libraryMediaUploadError) return;
                if (!msg) {
                    libraryMediaUploadError.classList.add("hidden");
                    libraryMediaUploadError.textContent = "";
                    return;
                }
                libraryMediaUploadError.textContent = msg;
                libraryMediaUploadError.classList.remove("hidden");
            }

            function renderLibraryMediaGrid() {
                if (!libraryMediaGrid) return;
                libraryMediaGrid.innerHTML = "";
                (libraryMedia || []).forEach((item) => {
                    const wrap = document.createElement("button");
                    wrap.type = "button";
                    wrap.className = "group relative overflow-hidden rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder bg-white text-left focus:outline-none focus:ring-2 focus:ring-brand-lightAccent";
                    wrap.title = item.displayName || item.filePath || "";
                    const thumb = document.createElement("img");
                    thumb.src = item.filePath || "";
                    thumb.alt = item.displayName || "";
                    thumb.className = "aspect-[4/3] h-auto w-full object-cover";
                    thumb.loading = "lazy";
                    wrap.appendChild(thumb);
                    const cap = document.createElement("span");
                    cap.className = "block truncate px-1.5 py-1 text-[10px] text-brand-lightMuted dark:text-brand-darkMuted";
                    cap.textContent = item.displayName || "";
                    wrap.appendChild(cap);
                    wrap.addEventListener("click", () => {
                        const img = resolveTargetImg();
                        if (!img) {
                            alert("Önce canvas üzerinde bir resim (img) veya içinde resim olan bir öğe seçin.");
                            return;
                        }
                        img.setAttribute("src", item.filePath || "");
                        selectNode(img);
                        closeLibraryMediaModal();
                    });
                    libraryMediaGrid.appendChild(wrap);
                });
            }

            function openLibraryMediaModal() {
                if (!libraryMediaModal) return;
                closeCanvasMediaModal();
                showLibraryMediaError("");
                renderLibraryMediaGrid();
                libraryMediaModal.classList.remove("hidden");
                libraryMediaModal.classList.add("flex");
            }

            function closeLibraryMediaModal() {
                if (!libraryMediaModal) return;
                libraryMediaModal.classList.add("hidden");
                libraryMediaModal.classList.remove("flex");
            }

            function openCanvasMediaModal() {
                if (!canvasMediaModal) return;
                closeLibraryMediaModal();
                showCanvasMediaError("");
                renderCanvasMediaGrid();
                canvasMediaModal.classList.remove("hidden");
                canvasMediaModal.classList.add("flex");
            }

            closeCanvasMediaModalBtn?.addEventListener("click", closeCanvasMediaModal);
            canvasMediaModal?.addEventListener("click", closeCanvasMediaModal);
            openLibraryMediaModalBtn?.addEventListener("click", openLibraryMediaModal);
            closeLibraryMediaModalBtn?.addEventListener("click", closeLibraryMediaModal);
            libraryMediaModal?.addEventListener("click", closeLibraryMediaModal);

            canvasMediaUploadForm?.addEventListener("submit", async (e) => {
                e.preventDefault();
                showCanvasMediaError("");
                const file = canvasMediaFileInput?.files?.[0];
                if (!file) {
                    showCanvasMediaError("Lütfen bir dosya seçin.");
                    return;
                }
                const fd = new FormData();
                fd.append("__RequestVerificationToken", requestToken);
                fd.append("pageId", String(pageId));
                fd.append("file", file);
                try {
                    const res = await fetch(mediaUploadUrl, { method: "POST", body: fd, credentials: "same-origin" });
                    const data = await res.json().catch(() => ({}));
                    if (!res.ok) {
                        showCanvasMediaError(data.error || "Yükleme başarısız.");
                        return;
                    }
                    pageMedia.push({
                        mediaFileId: data.mediaFileId,
                        filePath: data.filePath,
                        displayName: data.displayName || ""
                    });
                    if (canvasMediaFileInput) canvasMediaFileInput.value = "";
                    renderCanvasMediaGrid();
                } catch {
                    showCanvasMediaError("Ağ hatası.");
                }
            });

            libraryMediaUploadForm?.addEventListener("submit", async (e) => {
                e.preventDefault();
                showLibraryMediaError("");
                const file = libraryMediaFileInput?.files?.[0];
                if (!file) {
                    showLibraryMediaError("Lütfen bir dosya seçin.");
                    return;
                }
                const fd = new FormData();
                fd.append("__RequestVerificationToken", requestToken);
                fd.append("file", file);
                try {
                    const res = await fetch(libraryMediaUploadUrl, { method: "POST", body: fd, credentials: "same-origin" });
                    const data = await res.json().catch(() => ({}));
                    if (!res.ok) {
                        showLibraryMediaError(data.error || "Yükleme başarısız.");
                        return;
                    }
                    const row = {
                        mediaFileId: data.mediaFileId,
                        filePath: data.filePath,
                        displayName: data.displayName || ""
                    };
                    libraryMedia = [row, ...(libraryMedia || [])];
                    if (libraryMediaFileInput) libraryMediaFileInput.value = "";
                    renderLibraryMediaGrid();
                } catch {
                    showLibraryMediaError("Ağ hatası.");
                }
            });

            [textInput, hrefInput, srcInput, altInput, classInput, styleInput].forEach((el) => {
                el?.addEventListener("input", applyInputsToNode);
            });
            [nodeBackgroundColorInput, nodeTextColorInput, nodeBorderColorInput].forEach((el) => {
                el?.addEventListener("input", applySelectedNodeColors);
            });
            pageBackgroundColorInput?.addEventListener("input", applyPageBackgroundColor);
            paletteSelect?.addEventListener("change", applyPaletteFromSelection);

            document.querySelectorAll(".canvas-bp-tab").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const bp = btn.getAttribute("data-bp");
                    if (bp) switchBreakpoint(bp);
                });
            });

            window.addEventListener("resize", () => resizePreviewForBp());

            deleteNodeBtn?.addEventListener("click", () => {
                if (!selectedNode) return;
                const next = selectedNode.parentElement;
                selectedNode.remove();
                clearSelection();
                syncInputsFromNode();
                if (next) selectNode(next);
            });
            clearSelectionBtn?.addEventListener("click", () => {
                clearSelection();
                syncInputsFromNode();
            });

            saveBtn.addEventListener("click", () => {
                flushHtmlStore();
                htmlInput.value = htmlByBp.desktop || "";
                htmlTabletInput.value = htmlByBp.tablet || htmlByBp.desktop || "";
                htmlPhoneInput.value = htmlByBp.phone || htmlByBp.desktop || "";
                saveForm.submit();
            });

            loadCardDefinitionChips().finally(() => {
                activeBp = "desktop";
                loadHtmlIntoFrame(htmlByBp.desktop || "");
                updateBpTabStyles();
                resizePreviewForBp();
            });
            setPaletteSwatches(activePalette);
            if (activePalette?.SecondaryHex && pageBackgroundColorInput) {
                pageBackgroundColorInput.value = activePalette.SecondaryHex;
            }
        })();
    </script>
}
