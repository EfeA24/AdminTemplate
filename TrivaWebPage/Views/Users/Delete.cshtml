@model TrivaWebPage.Models.User
@{
    ViewData["Title"] = "Kullanıcı sil";
}

<div class="space-y-4">
    <h1 class="text-2xl font-semibold">Kullanıcı sil</h1>
    <p class="text-brand-lightMuted dark:text-brand-darkMuted">Şu kullanıcı silinecek: <strong>@Model.UserName</strong></p>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex gap-3">
        @Html.AntiForgeryToken()
        <button type="submit" class="rounded bg-red-600 text-white px-4 py-2">Sil</button>
        <a asp-action="Index">İptal</a>
    </form>
</div>
