@model TrivaWebPage.ViewModels.Admin.UserEditViewModel
@{
    var formAction = (ViewBag.FormAction as string) ?? "Create";
    ViewData["Title"] = formAction == "Create" ? "Kullanıcı oluştur" : "Kullanıcı düzenle";
}

<div class="space-y-4">
    <h1 class="text-2xl font-semibold">@ViewData["Title"]</h1>
    <form asp-action="@formAction" method="post" class="space-y-3 rounded-xl border border-brand-lightBorder dark:border-brand-darkBorder p-4 max-w-lg">
        @Html.AntiForgeryToken()
        @if (formAction == "Edit")
        {
            <input type="hidden" asp-for="Id" />
        }
        <div asp-validation-summary="All" class="text-red-600 text-sm"></div>
        <div class="space-y-1">
            <label asp-for="UserName" class="block text-sm font-medium"></label>
            <input asp-for="UserName" class="w-full rounded border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 bg-white dark:bg-brand-darkPanel text-brand-lightText dark:text-brand-darkText" autocomplete="username" />
            <span asp-validation-for="UserName" class="text-red-600 text-xs"></span>
        </div>
        <div class="space-y-1">
            <label asp-for="Password" class="block text-sm font-medium">Şifre @(formAction == "Edit" ? "(değiştirmek için doldurun)" : "")</label>
            <input asp-for="Password" type="password" class="w-full rounded border border-brand-lightBorder dark:border-brand-darkBorder px-3 py-2 bg-white dark:bg-brand-darkPanel text-brand-lightText dark:text-brand-darkText" autocomplete="@(formAction == "Create" ? "new-password" : "new-password")" placeholder="@(formAction == "Edit" ? "Boş bırakılırsa şifre değişmez" : "")" />
            <span asp-validation-for="Password" class="text-red-600 text-xs"></span>
        </div>
        <div class="flex gap-3">
            <button type="submit" class="rounded bg-brand-lightAccent dark:bg-brand-darkAccent text-white px-4 py-2">Kaydet</button>
            <a asp-action="Index" class="px-4 py-2">İptal</a>
        </div>
    </form>
</div>
